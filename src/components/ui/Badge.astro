---
type Tone = "neutral" | "success" | "warning" | "danger" | "info";

const { tone = "neutral" } = Astro.props as { tone?: Tone };
const tones: Record<Tone, string> = {
  neutral: "bg-white/10 text-slate-200",
  success: "bg-emerald-400/15 text-emerald-200",
  warning: "bg-amber-400/20 text-amber-200",
  danger: "bg-rose-400/20 text-rose-200",
  info: "bg-sky-400/20 text-sky-200",
};
---
<span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] ${tones[tone] ?? tones.neutral}`}>
  <slot />
</span>
