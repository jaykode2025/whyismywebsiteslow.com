---
import ScanForm from "./ScanForm.svelte";

interface Props {
  initialUrl?: string;
  csrfToken?: string;
}

const { initialUrl = "", csrfToken = "" } = Astro.props;
---

<div class="mt-8 mb-12 rounded-3xl border border-white/10 bg-slate-900/50 p-6 md:p-8 backdrop-blur-sm shadow-2xl">
  <div class="max-w-3xl">
    <ScanForm client:load initialUrl={initialUrl} csrfToken={csrfToken} />
    
    <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-400">
      <span class="flex items-center gap-1.5">
        <span class="text-emerald-400">✓</span> Free report
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-emerald-400">✓</span> No signup required
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-emerald-400">✓</span> Takes 10 seconds
      </span>
    </div>
  </div>
</div>
