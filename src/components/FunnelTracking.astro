<script is:inline>
  (() => {
    const endpoint = "/api/events";

    function send(payload) {
      const body = JSON.stringify(payload);
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon(endpoint, new Blob([body], { type: "application/json" }));
          return;
        }
      } catch {
        // Fallback to fetch.
      }
      fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body,
        keepalive: true,
      }).catch(() => {});
    }

    document.addEventListener("click", (event) => {
      const target = event.target instanceof Element ? event.target.closest("[data-track-event]") : null;
      if (!(target instanceof HTMLElement)) return;
      const eventType = target.dataset.trackEvent;
      if (!eventType) return;
      send({
        eventType,
        source: target.dataset.trackSource || null,
        ctaVariant: target.dataset.trackCtaVariant || null,
        offerContext: target.dataset.trackOfferContext || null,
        reportId: target.dataset.trackReportId || null,
        scanId: target.dataset.trackScanId || null,
        metadata: {
          href: target instanceof HTMLAnchorElement ? target.getAttribute("href") : null,
          text: (target.textContent || "").trim().slice(0, 120),
          path: window.location.pathname,
        },
      });
    });
  })();
</script>
