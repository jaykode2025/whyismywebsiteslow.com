---
type RelatedItem = {
  href: string;
  label: string;
};

const {
  items = [],
  heading = "Related next steps",
  intro = "Explore nearby pages selected by topic overlap.",
} = Astro.props as {
  items?: RelatedItem[];
  heading?: string;
  intro?: string;
};
---

{
  items.length > 0 ? (
    <section class="mb-10 rounded-2xl border border-white/10 bg-white/[0.03] p-6">
      <h2 class="text-xl text-slate-100">{heading}</h2>
      <p class="mt-1 text-sm text-slate-400">{intro}</p>
      <ul class="mt-4 grid gap-3 md:grid-cols-2">
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class="flex h-full items-center justify-between gap-3 rounded-xl border border-white/10 bg-slate-950/30 px-4 py-3 text-sm text-slate-200 transition hover:border-sky-400/40 hover:text-sky-100"
            >
              <span>{item.label}</span>
              <span aria-hidden="true" class="text-slate-500">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null
}
