---
import Logo from "./Logo.astro";
import Button from "./ui/Button.astro";
const path = Astro.url.pathname;
const isHome = path === "/";
const user = Astro.locals.user;
const isActive = (href: string) => (href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`));
const linkClass = (href: string) =>
  `transition hover:text-slate-100 ${isActive(href) ? "text-slate-100" : "text-slate-300"}`;
---
<header class="flex items-center justify-between py-8">
  <a href="/" class="flex items-center gap-3 text-slate-100">
    <Logo />
  </a>
  <nav class="hidden items-center gap-6 text-sm text-slate-300 md:flex">
    <a href="/scan" class={linkClass("/scan")}>Scan</a>
    {user ? <a href="/projects" class={linkClass("/projects")}>Projects</a> : null}
    {user ? <a href="/billing" class={linkClass("/billing")}>Billing</a> : null}
    <a href="/about" class={linkClass("/about")}>About</a>
    <a href="/api" class={linkClass("/api")}>API</a>
    <a href="/report/example" class={linkClass("/report")}>Examples</a>
    {!user ? <a href="/login" class={linkClass("/login")}>Log in</a> : null}
  </nav>
  <div class="flex items-center gap-3">
    {user ? (
      <Button href="/projects" variant={isHome ? "primary" : "ghost"}>Dashboard</Button>
    ) : (
      <>
        <a class="hidden text-sm text-slate-300 transition hover:text-slate-100 md:inline" href="/login">Log in</a>
        <Button href="/scan" variant={isHome ? "primary" : "ghost"}>Start a scan</Button>
      </>
    )}
    <details class="relative md:hidden">
      <summary class="cursor-pointer rounded-full border border-white/10 px-4 py-2 text-xs uppercase tracking-[0.18em] text-slate-300">
        Menu
      </summary>
      <div class="absolute right-0 mt-2 w-48 rounded-2xl border border-white/10 bg-[#0b1120] p-3 text-sm text-slate-200 shadow-2xl">
        <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/scan") ? "bg-white/5 text-slate-100" : ""}`} href="/scan">Scan</a>
        {user ? <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/projects") ? "bg-white/5 text-slate-100" : ""}`} href="/projects">Projects</a> : null}
        {user ? <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/billing") ? "bg-white/5 text-slate-100" : ""}`} href="/billing">Billing</a> : null}
        <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/about") ? "bg-white/5 text-slate-100" : ""}`} href="/about">About</a>
        <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/api") ? "bg-white/5 text-slate-100" : ""}`} href="/api">API</a>
        <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/report") ? "bg-white/5 text-slate-100" : ""}`} href="/report/example">Examples</a>
        {!user ? <a class={`block rounded-lg px-3 py-2 transition hover:bg-white/5 ${isActive("/login") ? "bg-white/5 text-slate-100" : ""}`} href="/login">Log in</a> : null}
      </div>
    </details>
  </div>
</header>
