---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { PLATFORMS, PROBLEMS } from "../../../data/pseo";
import { siteUrl, breadcrumb, organizationSchema, calculateKeywordDensity } from "../../../lib/seo";
import { relatedForPlatform } from "../../../lib/related";
import RelatedLinks from "../../../components/seo/RelatedLinks.astro";
import ProofBlock from "../../../components/seo/ProofBlock.astro";
import { buildPlatformProofDataset } from "../../../lib/proof";
import { deriveVariationTokens, sectionOrderMap, shouldRenderOptionalSection } from "../../../lib/variation";

export const prerender = false;

const platform = PLATFORMS.find((p) => p.platform === Astro.params.slug);
if (!platform) {
  throw new Error(`Platform not found for: ${Astro.params.slug ?? "unknown"}`);
}

const relatedProblems = PROBLEMS.filter((problem) => problem.platform === platform.platform).slice(0, 6);
const relatedLinks = relatedForPlatform(platform.platform, 5);
const proofDataset = buildPlatformProofDataset(
  platform,
  relatedProblems.map((problem) => problem.issueTitle)
);

const variationTokens = deriveVariationTokens({
  slug: `platform:${platform.platform}`,
  availableSections: ["issues", "solutions", "load-times", "related", "references"],
});
const sectionOrder = sectionOrderMap(variationTokens.sectionOrder);
const showReferences = shouldRenderOptionalSection(variationTokens, "resources");
const ogImage = siteUrl(`/og/platform/${platform.platform}.svg`);

const breadcrumbSchema = breadcrumb([
  { name: "Home", item: "/" },
  { name: "Website Speed Audit", item: "/website-speed-audit/" },
  { name: platform.platform, item: `/website-speed-audit/platform/${platform.platform}/` }
]);
const orgSchema = organizationSchema();

const allContent = `${platform.topIssues.join(" ")} ${platform.commonSolutions.join(" ")}`;
const keywordDensity = calculateKeywordDensity(allContent, platform.keyword);
const description = `Comprehensive speed audit for ${platform.platform} websites. Identify bottlenecks and prioritize fixes with real benchmark data.`;

const ctaPrimaryHref = variationTokens.ctaVariant === "pricing" ? "/billing" : "/scan";
const ctaPrimaryLabel = variationTokens.ctaVariant === "pricing" ? "Start Monitoring" : "Run Another Scan";
---

<BaseLayout
  title={platform.keyword}
  description={description}
  canonical={siteUrl(`/website-speed-audit/platform/${platform.platform}/`)}
  ogImage={ogImage}
>
  <script slot="head" type="application/ld+json" is:inline>{JSON.stringify(breadcrumbSchema)}</script>
  <script slot="head" type="application/ld+json" is:inline>{JSON.stringify(orgSchema)}</script>

  <section class="mb-10 rounded-3xl border border-white/10 bg-gradient-to-br from-cyan-600/20 via-blue-600/20 to-slate-950/30 p-8">
    <nav aria-label="Breadcrumb" class="mb-5 text-sm text-slate-400">
      <a href="/" class="hover:text-sky-300">Home</a>
      <span class="mx-2">/</span>
      <a href="/website-speed-audit/" class="hover:text-sky-300">Website Speed Audit</a>
      <span class="mx-2">/</span>
      <span class="text-slate-200">{platform.platform}</span>
    </nav>
    <h1 class="text-4xl font-bold text-slate-100">{platform.keyword}</h1>
    <p class="mt-3 max-w-3xl text-lg text-slate-300">
      Focused optimization playbook for {platform.platform} sites, with benchmark-backed priorities.
    </p>
  </section>

  <ProofBlock
    title={`${platform.platform} performance proof`}
    subtitle="Exactly one proof format is selected per page using deterministic variation tokens."
    proofType={variationTokens.proofType}
    visualMode={variationTokens.visualMode}
    dataset={proofDataset}
    slug={`platform-${platform.platform}`}
  />

  <div class="mb-8 flex flex-col">
    <section class="mb-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6" style={`order:${sectionOrder["issues"] ?? 1}`}>
      <h2 class="text-2xl text-slate-100">Common performance issues with {platform.platform}</h2>
      <ul class="mt-4 grid gap-2 text-slate-300 md:grid-cols-2">
        {platform.topIssues.map((issue) => <li class="rounded-lg border border-white/10 bg-slate-950/30 px-3 py-2">{issue}</li>)}
      </ul>
    </section>

    <section class="mb-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6" style={`order:${sectionOrder["solutions"] ?? 2}`}>
      <h2 class="text-2xl text-slate-100">Best solutions</h2>
      <ul class="mt-4 grid gap-2 text-slate-300 md:grid-cols-2">
        {platform.commonSolutions.map((solution) => <li class="rounded-lg border border-white/10 bg-slate-950/30 px-3 py-2">{solution}</li>)}
      </ul>
    </section>

    <section class="mb-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6" style={`order:${sectionOrder["load-times"] ?? 3}`}>
      <h2 class="text-2xl text-slate-100">Average load times</h2>
      <p class="mt-3 text-slate-300">
        Typical {platform.platform} sites load in <strong>{platform.avgLoadTime}</strong>. Reaching sub-2.5s LCP is usually realistic after fixing top bottlenecks.
      </p>
      <p class="mt-2 text-xs text-slate-500">Keyword density marker: {keywordDensity}%</p>
    </section>

    {showReferences ? (
      <section class="mb-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6" style={`order:${sectionOrder["references"] ?? 4}`}>
        <h2 class="text-2xl text-slate-100">References</h2>
        <ul class="mt-4 space-y-2 text-slate-300">
          <li><a href="https://developers.google.com/speed/docs/insights/v5/about" target="_blank" rel="noopener noreferrer" class="hover:text-sky-300">Google PageSpeed Insights Documentation</a></li>
          <li><a href="https://web.dev/articles/vitals" target="_blank" rel="noopener noreferrer" class="hover:text-sky-300">Core Web Vitals on web.dev</a></li>
          <li><a href="https://developer.mozilla.org/en-US/docs/Web/Performance" target="_blank" rel="noopener noreferrer" class="hover:text-sky-300">MDN Web Performance Guide</a></li>
        </ul>
      </section>
    ) : null}
  </div>

  <RelatedLinks items={relatedLinks} heading={`Related ${platform.platform} pages`} />

  <aside class="mb-10 rounded-3xl border border-white/10 bg-gradient-to-r from-sky-600/20 via-indigo-600/20 to-emerald-600/20 p-8">
    <h2 class="text-2xl text-slate-100">Ready to optimize your {platform.platform} site?</h2>
    <p class="mt-2 text-slate-300">Start with a fresh scan and get a prioritized, dev-ready action list.</p>
    <div class="mt-5 flex flex-wrap items-center gap-3">
      <a href={ctaPrimaryHref} class="rounded-xl bg-sky-500 px-6 py-3 font-semibold text-white hover:bg-sky-400">{ctaPrimaryLabel}</a>
      {variationTokens.ctaVariant === "email" ? (
        <form method="post" action="/api/leads/preview" class="flex flex-wrap items-center gap-2">
          <input type="hidden" name="source" value={`seo-platform:${platform.platform}`} />
          <input type="hidden" name="next" value={`/website-speed-audit/platform/${platform.platform}/`} />
          <input type="email" name="email" required placeholder="Weekly performance tips" class="rounded-xl border border-white/20 bg-slate-950/60 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-400" />
          <button type="submit" class="rounded-xl border border-emerald-300/40 bg-emerald-500/20 px-4 py-3 text-sm font-semibold text-emerald-100 hover:bg-emerald-500/30">Email me</button>
        </form>
      ) : null}
    </div>
  </aside>
</BaseLayout>
