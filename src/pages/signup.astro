---
import BaseLayout from "../layouts/BaseLayout.astro";

const next = Astro.url.searchParams.get("next") ?? "/billing";
---

<BaseLayout title="Sign up">
  <section class="mx-auto max-w-md px-4 py-16">
    <h1 class="text-3xl font-semibold text-slate-100">Create account</h1>
    <p class="mt-2 text-sm text-slate-400">Create an account to save projects and track scan history.</p>

    <form class="mt-8 space-y-4" method="post" action="/api/auth/signup">
      <input type="hidden" name="next" value={next} />

      <label class="block text-sm text-slate-300">
        Email
        <input
          class="mt-2 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100"
          type="email"
          name="email"
          required
          autocomplete="email"
        />
      </label>

      <label class="block text-sm text-slate-300">
        Password
        <input
          class="mt-2 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100"
          type="password"
          name="password"
          required
          minlength="8"
          autocomplete="new-password"
        />
      </label>

      <button class="w-full rounded-xl bg-emerald-400 px-4 py-3 font-medium text-slate-950 hover:bg-emerald-300" type="submit">
        Sign up
      </button>

      <p class="text-sm text-slate-400">
        Already have an account?
        <a class="text-sky-200 hover:underline" href={`/login?next=${encodeURIComponent(next)}`}>Log in</a>
      </p>
    </form>
  </section>
</BaseLayout>

