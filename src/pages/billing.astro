---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import { getUserPlan, isPro, type PlanInfo } from "../lib/plan";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/login?next=${encodeURIComponent("/billing")}`);
}

const supabase = Astro.locals.supabase;
const planInfo: PlanInfo = supabase
  ? await getUserPlan(supabase, user.id)
  : { plan: "free", status: "inactive", currentPeriodEnd: null };
---

<BaseLayout title="Billing">
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-semibold text-slate-100">Billing</h1>
        <p class="mt-2 text-sm text-slate-400">Manage your subscription and upgrade for monitoring features.</p>
      </div>
      <form method="post" action="/api/auth/logout">
        <Button type="submit" variant="ghost" size="sm" class="border-white/10">
          Log out
        </Button>
      </form>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Current plan</p>
        <p class="mt-3 text-2xl text-slate-100">{planInfo.plan.toUpperCase()}</p>
        <p class="mt-1 text-sm text-slate-400">Status: {planInfo.status}</p>
        {planInfo.currentPeriodEnd ? (
          <p class="mt-1 text-xs text-slate-500">Renews: {new Date(planInfo.currentPeriodEnd).toLocaleDateString()}</p>
        ) : null}
      </Card>

      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Upgrade</p>
        <p class="mt-2 text-sm text-slate-300">
          Pro unlocks more saved projects, deeper crawl options, and scheduled monitoring (coming soon).
        </p>

        {isPro(planInfo) ? (
          <p class="mt-4 rounded-xl border border-emerald-300/30 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-100">
            You’re on Pro.
          </p>
        ) : (
          <form class="mt-4" method="post" action="/api/billing/checkout">
            <Button type="submit" size="lg" class="w-full rounded-xl">
              Upgrade to Pro
            </Button>
          </form>
        )}
      </Card>
    </div>
  </section>
</BaseLayout>
