---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import { getPlanLimits, getUserPlan, isPro, type PlanInfo } from "../lib/plan";

const user = Astro.locals.user ?? null;
const supabase = Astro.locals.supabase;
const isAuthed = Boolean(user);
const planInfo: PlanInfo = user && supabase
  ? await getUserPlan(supabase, user.id)
  : { plan: "free", status: "inactive", currentPeriodEnd: null };
const limits = getPlanLimits(planInfo.plan);
---

<BaseLayout title="Pricing and Billing" description="Free scan, $19 report unlock, $12/month monitoring, and $149+ done-for-you fixes.">
  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-semibold text-slate-100">Pricing and Billing</h1>
        <p class="mt-2 text-sm text-slate-400">Start with a free scan, then choose the level of help you need.</p>
      </div>
      {isAuthed ? (
        <form method="post" action="/api/auth/logout">
          <Button type="submit" variant="ghost" size="sm" class="border-white/10">
            Log out
          </Button>
        </form>
      ) : (
        <div class="flex items-center gap-3">
          <Button href="/login?next=%2Fbilling" variant="ghost" size="sm" class="border-white/10">Log in</Button>
          <Button href="/signup?next=%2Fbilling" size="sm">Create account</Button>
        </div>
      )}
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{isAuthed ? "Current setup" : "How pricing works"}</p>
        <p class="mt-3 text-2xl text-slate-100">{isAuthed ? planInfo.plan.toUpperCase() : "Start Free"}</p>
        <p class="mt-1 text-sm text-slate-400">{isAuthed ? `Status: ${planInfo.status}` : "No login required to run your first scan."}</p>
        <p class="mt-4 text-sm text-slate-300">
          Free is for diagnosis. The $19 unlock is for a one-time full implementation plan. Monitoring is for ongoing regression protection. Done-for-you fixes are for teams that want execution support.
        </p>
        <div class="mt-4 space-y-2 text-xs text-slate-400">
          <p>Projects included: {limits.maxProjects}</p>
          <p>Monthly scans included: {limits.monthlyScanLimit}</p>
        </div>
        {isAuthed && planInfo.currentPeriodEnd ? (
          <p class="mt-1 text-xs text-slate-500">Renews: {new Date(planInfo.currentPeriodEnd).toLocaleDateString()}</p>
        ) : null}
        <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Offer ladder</p>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            <li>Free scan: diagnosis and preview</li>
            <li>$19 detailed report: one-time unlock from the report page</li>
            <li>$12/month monitoring: recurring scans and regressions</li>
            <li>$149+ fix-it service: done-for-you implementation help</li>
          </ul>
        </div>
      </Card>

      <div class="grid gap-6 md:grid-cols-2">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Detailed report</p>
          <h2 class="mt-2 text-2xl text-slate-100">Full report - $19</h2>
          <p class="mt-3 text-sm text-slate-300">
            Best if you want a complete one-time fix checklist after running a scan.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li>Full ranked fix list</li>
            <li>Deeper implementation notes</li>
            <li>One-time purchase on a per-report basis</li>
          </ul>
          <div class="mt-6 space-y-3">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
              Buy this from the report page after you run a free scan.
            </div>
            <Button href="/scan" variant="ghost" class="w-full rounded-xl border-white/10" data-track-event="homepage_cta_clicked" data-track-source="billing-report-card" data-track-offer-context="free-scan" data-track-cta-variant="secondary">
              Scan your site free
            </Button>
          </div>
        </Card>

        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Monitoring</p>
          <h2 class="mt-2 text-2xl text-slate-100">Monitoring - $12/month</h2>
          <p class="mt-3 text-sm text-slate-300">
            Best if you want ongoing visibility into regressions, scan history, and repeated checks after fixes ship.
          </p>

          {isPro(planInfo) ? (
            <p class="mt-4 rounded-xl border border-emerald-300/30 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-100">
              You're on {planInfo.plan === "agency" ? "a legacy Agency" : "the Monitoring"} plan.
            </p>
          ) : isAuthed ? (
            <div class="mt-4 space-y-3">
              <form method="post" action="/api/billing/checkout">
                <input type="hidden" name="plan" value="pro" />
                <input type="hidden" name="offerContext" value="billing-monitoring" />
                <input type="hidden" name="ctaVariant" value="primary" />
                <Button type="submit" size="lg" class="w-full rounded-xl">
                  Start monitoring - $12/month
                </Button>
              </form>
            </div>
          ) : (
            <div class="mt-4 space-y-3">
              <Button href="/signup?next=%2Fbilling" size="lg" class="w-full rounded-xl">
                Create account to start monitoring
              </Button>
              <p class="text-xs text-slate-400">Checkout requires an account so monitoring can be tied to your projects.</p>
            </div>
          )}
          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li>Recurring scans and score tracking</li>
            <li>Regression alerts and project history</li>
            <li>Simple plan for site owners and small teams</li>
          </ul>
        </Card>
      </div>
    </div>

    <div class="mt-8">
      <Card class="border-amber-400/20 bg-amber-400/5">
        <p class="text-xs uppercase tracking-[0.2em] text-amber-200/80">Done-for-you option</p>
        <div class="mt-3 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-2xl text-slate-100">Need the fixes handled for you? Starts at $149.</h2>
            <p class="mt-2 text-sm text-slate-300">
              Use the scanner to diagnose the problem, then hand off implementation if speed is hurting leads or revenue now.
            </p>
          </div>
          <Button href="/fix-it" size="lg" variant="ghost" class="rounded-xl border-white/10" data-track-event="service_cta_clicked" data-track-source="billing-service-card" data-track-offer-context="service" data-track-cta-variant="primary">
            Request help fixing it
          </Button>
        </div>
        <ul class="mt-4 grid gap-3 text-sm text-slate-300 md:grid-cols-3">
          <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Caching and server response cleanup</li>
          <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">Image, script, and third-party optimization</li>
          <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">CMS, hosting, and monitoring recommendations</li>
        </ul>
      </Card>
    </div>
  </section>
</BaseLayout>
