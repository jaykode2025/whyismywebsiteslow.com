---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import { INDUSTRIES, LOCATIONS, PLATFORMS, PROBLEMS } from "../data/pseo";
import { breadcrumb, organizationSchema, siteUrl } from "../lib/seo";

const title = "How the SEO Engine Works";
const description =
  "See how Why Is My Website Slow turns structured performance data into scalable SEO landing pages for problems, platforms, and industries.";

const breadcrumbJsonLd = JSON.stringify(
  breadcrumb([
    { name: "Home", item: "/" },
    { name: "About SEO Engine", item: "/about-seo-engine/" },
  ])
);
const organizationJsonLd = JSON.stringify(organizationSchema());
void breadcrumbJsonLd;
void organizationJsonLd;

const totalPages = PROBLEMS.length + PLATFORMS.length + INDUSTRIES.length + LOCATIONS.length;
---

<BaseLayout title={title} description={description} canonical={siteUrl("/about-seo-engine/")}>
  <script slot="head" type="application/ld+json" is:inline>{breadcrumbJsonLd}</script>
  <script slot="head" type="application/ld+json" is:inline>{organizationJsonLd}</script>

  <section class="animate-fade-up pt-10">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="space-y-6">
        <Badge tone="info">Programmatic SEO system</Badge>
        <h1 class="text-4xl leading-tight text-slate-100 sm:text-5xl">
          The SEO engine is structured content, not page spam.
        </h1>
        <p class="max-w-3xl text-lg text-slate-300">
          Why Is My Website Slow uses data-first templates to publish pages for specific speed
          problems, platforms, and industries. The goal is simple: capture high-intent search
          traffic with pages that are useful before a visitor ever runs a scan.
        </p>
        <div class="flex flex-wrap gap-3">
          <Button href="/why-is-my-website-slow">Browse issue pages</Button>
          <Button href="/website-speed-audit" variant="ghost">Browse audit pages</Button>
        </div>
      </div>

      <Card class="glow">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Coverage snapshot</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl text-sky-200">{PROBLEMS.length}</div>
            <p class="mt-1 text-sm text-slate-400">Problem pages</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl text-emerald-200">{PLATFORMS.length}</div>
            <p class="mt-1 text-sm text-slate-400">Platform pages</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl text-violet-200">{INDUSTRIES.length}</div>
            <p class="mt-1 text-sm text-slate-400">Industry pages</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl text-amber-200">{totalPages}</div>
            <p class="mt-1 text-sm text-slate-400">Current total combinations</p>
          </div>
        </div>
        <p class="mt-5 text-sm text-slate-300">
          Each page is generated from structured inputs in <code>src/data/pseo.ts</code>, then
          wrapped with metadata, related links, proof blocks, and conversion CTAs.
        </p>
      </Card>
    </div>
  </section>

  <section class="mt-18 animate-fade-up">
    <div class="grid gap-6 md:grid-cols-3 stagger">
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Step 1</p>
        <h2 class="mt-4 text-2xl text-slate-100">Structured inputs</h2>
        <p class="mt-3 text-sm text-slate-300">
          Problem, platform, industry, and location entries define the keywords, headlines,
          supporting facts, and recommended fixes that power each page.
        </p>
      </Card>
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Step 2</p>
        <h2 class="mt-4 text-2xl text-slate-100">Reusable Astro templates</h2>
        <p class="mt-3 text-sm text-slate-300">
          Templates turn those entries into fully-rendered landing pages with schema, proof
          sections, internal linking, and branded calls to action.
        </p>
      </Card>
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Step 3</p>
        <h2 class="mt-4 text-2xl text-slate-100">Conversion path</h2>
        <p class="mt-3 text-sm text-slate-300">
          Every page funnels visitors toward a scan, report unlock, or service lead instead of
          acting like isolated blog content.
        </p>
      </Card>
    </div>
  </section>

  <section class="mt-18 animate-fade-up">
    <Card>
      <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">URL structure</p>
          <h2 class="mt-4 text-3xl text-slate-100">Everything stays on the main domain</h2>
          <p class="mt-3 text-slate-300">
            The system keeps SEO authority consolidated under <strong>whyismywebsiteslow.com</strong>
            instead of pushing content onto subdomains.
          </p>
        </div>
        <div class="space-y-3 text-sm text-slate-300">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <p class="text-slate-100">Problem pages</p>
            <code class="mt-2 block text-sky-200">/why-is-my-website-slow/[issue]/</code>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <p class="text-slate-100">Platform pages</p>
            <code class="mt-2 block text-emerald-200">/website-speed-audit/platform/[platform]/</code>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <p class="text-slate-100">Industry pages</p>
            <code class="mt-2 block text-violet-200">/website-speed-audit/industry/[industry]/</code>
          </div>
        </div>
      </div>
    </Card>
  </section>

  <section class="mt-18 animate-fade-up">
    <div class="grid gap-6 lg:grid-cols-3">
      <Card>
        <h2 class="text-2xl text-slate-100">Issue examples</h2>
        <ul class="mt-4 space-y-3 text-sm text-slate-300">
          {PROBLEMS.slice(0, 4).map((problem) => (
            <li>
              <a class="transition hover:text-sky-200" href={`/why-is-my-website-slow/${problem.slug}/`}>
                {problem.keyword}
              </a>
            </li>
          ))}
        </ul>
      </Card>
      <Card>
        <h2 class="text-2xl text-slate-100">Platform examples</h2>
        <ul class="mt-4 space-y-3 text-sm text-slate-300">
          {PLATFORMS.slice(0, 4).map((platform) => (
            <li>
              <a
                class="transition hover:text-sky-200"
                href={`/website-speed-audit/platform/${platform.platform}/`}
              >
                {platform.keyword}
              </a>
            </li>
          ))}
        </ul>
      </Card>
      <Card>
        <h2 class="text-2xl text-slate-100">Industry examples</h2>
        <ul class="mt-4 space-y-3 text-sm text-slate-300">
          {INDUSTRIES.slice(0, 4).map((industry) => (
            <li>
              <a
                class="transition hover:text-sky-200"
                href={`/website-speed-audit/industry/${industry.industry}/`}
              >
                {industry.keyword}
              </a>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </section>

  <section class="mt-18 animate-fade-up">
    <Card class="border-amber-400/20 bg-amber-400/5">
      <p class="text-xs uppercase tracking-[0.2em] text-amber-200/80">Why this matters</p>
      <h2 class="mt-4 text-3xl text-slate-100">The project now reads like one product</h2>
      <p class="mt-3 max-w-4xl text-slate-300">
        The scan flow, programmatic SEO pages, and service offer should feel like parts of the same
        business. This page exists to make that architecture legible to collaborators, clients, and
        future maintainers.
      </p>
    </Card>
  </section>
</BaseLayout>
