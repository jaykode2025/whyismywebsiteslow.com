---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import { createSupabaseAdminClient } from "../../lib/supabase/admin";
import { buildProjectHealthSummary, buildRegressionSummary } from "../../lib/monitoringSummary";

const user = Astro.locals.user;
if (!user) return Astro.redirect(`/login?next=${encodeURIComponent(Astro.url.pathname)}`);
const supabase = Astro.locals.supabase!;

const projectId = Astro.params.id ?? "";

const { data: project } = await supabase.from("projects").select("id,url,name,created_at").eq("id", projectId).maybeSingle();
if (!project) {
  return new Response("Not found", { status: 404 });
}

const admin = createSupabaseAdminClient();
const scansClient = admin ?? supabase;
const { data: scans } = await scansClient
  .from("scans")
  .select("id,project_id,url,status,device,visibility,created_at,summary_json,report_json,error")
  .eq("project_id", projectId)
  .eq("user_id", user.id)
  .order("created_at", { ascending: false })
  .limit(50);

const projectScans = (scans ?? []) as any[];
const healthSummary = buildProjectHealthSummary(projectId, projectScans);
const regressionSummary = buildRegressionSummary(projectId, project.url, projectScans);
---

<BaseLayout title={project.name ?? "Project"}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-semibold text-slate-100">{project.name ?? project.url}</h1>
        <p class="mt-2 text-sm text-slate-400">{project.url}</p>
      </div>
      <div class="flex gap-3">
        <Button href="/scan" variant="ghost">New scan</Button>
        <Button href="/billing">Upgrade</Button>
      </div>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <Card>
        <h2 class="text-xl text-slate-100">Monitoring overview</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Latest score</p>
            <p class="mt-2 text-2xl text-slate-100">{healthSummary.latestScore ?? "-"}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Trend</p>
            <p class="mt-2 text-2xl text-slate-100">{healthSummary.trend}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Current CWV</p>
            <p class="mt-2 text-slate-100">{healthSummary.latestCwvStatus ?? "-"}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Last scan</p>
            <p class="mt-2 text-slate-100">
              {healthSummary.lastScannedAt ? new Date(healthSummary.lastScannedAt).toLocaleDateString() : "-"}
            </p>
          </div>
        </div>
        <p class="mt-4 text-sm text-slate-400">
          Monitoring becomes useful when you can see whether performance is holding, improving, or regressing between scans.
        </p>
      </Card>

      <Card>
        <h2 class="text-xl text-slate-100">Recent regression check</h2>
        {regressionSummary ? (
          <div class="mt-4 rounded-2xl border border-rose-300/30 bg-rose-300/10 px-4 py-4">
            <p class="text-sm text-rose-100">{regressionSummary.summary}</p>
            <p class="mt-2 text-xs text-rose-100/70">
              Previous score: {regressionSummary.previousScore ?? "-"} · Current score: {regressionSummary.currentScore ?? "-"}
            </p>
          </div>
        ) : (
          <div class="mt-4 rounded-2xl border border-emerald-300/30 bg-emerald-300/10 px-4 py-4">
            <p class="text-sm text-emerald-100">No meaningful regression detected from the two most recent completed scans.</p>
          </div>
        )}
        <p class="mt-4 text-sm text-slate-400">
          Paid monitoring uses this same history to highlight regressions before they become customer-facing problems.
        </p>
        <div class="mt-4">
          <Button href="/billing" variant="ghost" class="border-white/10">Manage monitoring plan</Button>
        </div>
      </Card>
    </div>

    <Card class="mt-8">
      <h2 class="text-xl text-slate-100">Scan history</h2>
      <div class="mt-6 grid gap-3">
        {(scans ?? []).length === 0 ? (
          <p class="text-sm text-slate-300">No scans yet.</p>
        ) : (
          (scans ?? []).map((s) => (
            <a class="rounded-2xl border border-white/10 bg-white/5 p-4 hover:bg-white/10" href={`/report/${s.id}`}>
              <div class="flex items-center justify-between gap-4">
                <p class="text-sm text-slate-100">{s.id}</p>
                <p class="text-xs uppercase tracking-[0.16em] text-slate-400">{s.status}</p>
              </div>
              <p class="mt-2 text-xs text-slate-400">
                {s.device} · {s.visibility} · {new Date(s.created_at).toLocaleString()}
              </p>
              {s.summary_json ? (
                <p class="mt-2 text-sm text-slate-200">
                  Grade {(s.summary_json as any).grade} · {(s.summary_json as any).score100}/100
                </p>
              ) : s.error ? (
                <p class="mt-2 text-sm text-rose-200">{s.error}</p>
              ) : null}
            </a>
          ))
        )}
      </div>
    </Card>
  </section>
</BaseLayout>
