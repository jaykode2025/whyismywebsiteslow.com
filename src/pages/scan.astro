---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import ScanForm from "../components/ScanForm.svelte";

const title = "Run a performance scan";
const description = "Launch a scan with advanced options and shareable report settings.";
---
<BaseLayout title={title} description={description}>
  <section class="pt-10 animate-fade-up">
    <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr] stagger">
      <Card>
        <h1 class="text-3xl text-slate-100">Advanced scan</h1>
        <p class="mt-3 text-slate-300">
          Choose device, crawl up to five internal pages, and decide if the report can be indexed.
        </p>
        <div class="mt-6">
          <ScanForm client:load showAdvanced={true} csrfToken={Astro.locals.csrfToken ?? ""} />
        </div>
      </Card>
      <Card>
        <h2 class="text-xl text-slate-100">What happens next</h2>
        <ol class="mt-4 list-decimal space-y-2 pl-5 text-sm text-slate-300">
          <li>We queue a scan for your URL.</li>
          <li>We fetch PageSpeed Insights as the performance source of truth and pair it with our own checks.</li>
          <li>We generate a score, business-impact framing, and a prioritized fix list.</li>
          <li>Your report is saved as an immutable snapshot.</li>
        </ol>
        <p class="mt-4 text-xs text-slate-500">
          For best results, scan production URLs with real caching, media, and third-party scripts enabled.
        </p>
      </Card>
    </div>
  </section>
</BaseLayout>
