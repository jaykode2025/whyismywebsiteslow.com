---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import ScoreDonut from "../../components/ScoreDonut.svelte";
import ReportFilters from "../../components/ReportFilters.svelte";
import ScanProgress from "../../components/ScanProgress.svelte";
import ShareActions from "../../components/ShareActions.svelte";
import LockedOverlay from "../../components/LockedOverlay.astro";
import { loadStoredReport } from "../../lib/reports";
import { exampleReport } from "../../lib/example";
import { isReportUnlocked } from "../../lib/entitlements";
import { hasLeadAccess, LEAD_ACCESS_COOKIE_NAME } from "../../lib/leadAccess";
import { trackEvent } from "../../lib/analytics";

const { id } = Astro.params;
const stored = id === "example" ? { status: "done", report: exampleReport() } : await loadStoredReport(id ?? "", Astro.locals);
const report = stored?.report;
const unlocked = report ? (report.id === "example" ? true : await isReportUnlocked(report.id, Astro.locals)) : false;
const leadAccessCookie = Astro.cookies.get(LEAD_ACCESS_COOKIE_NAME)?.value;
const previewUnlocked = report ? unlocked || hasLeadAccess(leadAccessCookie, report.id) : false;

const title = report
  ? `Why is ${report.canonicalHost} slow? Report + Fixes`
  : "Report in progress";
const description = report
  ? `Performance report for ${report.canonicalHost} with grade ${report.summary.grade} and top fixes.`
  : "We are generating your performance report.";

const noindex = !report || report.visibility !== "public";
const jsonLd = report
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `Why is ${report.canonicalHost} slow?`,
      description,
      url: `${Astro.site?.origin ?? Astro.url.origin}/report/${report.id}`,
      isPartOf: {
        "@type": "SoftwareApplication",
        name: "whyismywebsiteslow",
        applicationCategory: "DeveloperApplication",
        operatingSystem: "Web",
      },
    }
  : null;

const formatMs = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  return value >= 1000 ? `${(value / 1000).toFixed(1)}s` : `${Math.round(value)} ms`;
};

const formatBytes = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  const mb = value / 1_000_000;
  return mb >= 1 ? `${mb.toFixed(2)} MB` : `${Math.round(value / 1000)} KB`;
};

const formatPercent = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  return `${value.toFixed(2)}%`;
};

const titleCase = (value: string) =>
  value
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const joinWithAnd = (items: string[]) => {
  if (items.length === 0) return "";
  if (items.length === 1) return items[0];
  if (items.length === 2) return `${items[0]} and ${items[1]}`;
  return `${items.slice(0, -1).join(", ")}, and ${items.at(-1)}`;
};

const impactRank = { high: 3, medium: 2, low: 1 };
const severityRank = { critical: 4, high: 3, medium: 2, low: 1 };
const effortRank = { low: 1, medium: 2, high: 3 };

const topInsights = report
  ? [...report.insights]
      .sort(
        (a, b) =>
          impactRank[b.impact] - impactRank[a.impact] ||
          severityRank[b.severity] - severityRank[a.severity] ||
          effortRank[a.effort] - effortRank[b.effort]
      )
      .slice(0, 3)
  : [];

const groupedInsights = report && unlocked
  ? Object.entries(
      report.insights.reduce((acc, insight) => {
        const key = insight.category;
        acc[key] = acc[key] ?? [];
        acc[key].push(insight);
        return acc;
      }, {} as Record<string, typeof report.insights>)
    )
  : [];

const topIssueTitles = topInsights.map((item) => item.title);
const timeline = report
  ? {
      ttfb: report.psi.cwv.ttfb_ms ?? 0,
      fcp: report.psi.cwv.fcp_ms ?? 0,
      lcp: report.psi.cwv.lcp_ms ?? 0,
    }
  : null;
const timelineMax = timeline ? Math.max(timeline.ttfb, timeline.fcp, timeline.lcp, 1) : 1;
const timelinePct = (value: number) => Math.min(100, (value / timelineMax) * 100);

const expectedImprovement = report
  ? (category: string) => {
      switch (category) {
        case "javascript":
        case "third-party":
          return "Likely improves interactivity and reduces main-thread blocking.";
        case "server":
        case "cdn":
          return report.psi.cwv.ttfb_ms && report.psi.cwv.ttfb_ms > 800
            ? `Could bring server response down from ${formatMs(report.psi.cwv.ttfb_ms)} toward recommended response times.`
            : "Should make first byte delivery more consistent.";
        case "images":
          return "Should cut page weight and improve the largest visual load on the page.";
        case "css":
        case "fonts":
          return "Should bring first paint forward and reduce render-blocking work.";
        case "core-web-vitals":
          return "Should improve the user-visible load experience that affects CWV pass/fail.";
        default:
          return "Should reduce load friction and make the page feel faster.";
      }
    }
  : () => "";

const toneClass = (value: string, kind: "impact" | "effort" | "status") => {
  if (kind === "impact") {
    return value === "high"
      ? "border-rose-400/30 bg-rose-400/10 text-rose-200"
      : value === "medium"
        ? "border-amber-400/30 bg-amber-400/10 text-amber-200"
        : "border-emerald-400/30 bg-emerald-400/10 text-emerald-200";
  }

  if (kind === "effort") {
    return value === "low"
      ? "border-emerald-400/30 bg-emerald-400/10 text-emerald-200"
      : value === "medium"
        ? "border-amber-400/30 bg-amber-400/10 text-amber-200"
        : "border-slate-400/30 bg-slate-400/10 text-slate-200";
  }

  return value === "good"
    ? "border-emerald-400/30 bg-emerald-400/10 text-emerald-200"
    : value === "needs work"
      ? "border-amber-400/30 bg-amber-400/10 text-amber-200"
      : "border-rose-400/30 bg-rose-400/10 text-rose-200";
};

const comparisonRows = report
  ? [
      {
        label: "Largest Contentful Paint",
        current: formatMs(report.psi.cwv.lcp_ms),
        target: "2.5s or less",
        status:
          report.psi.cwv.lcp_ms === undefined
            ? "needs work"
            : report.psi.cwv.lcp_ms <= 2500
              ? "good"
              : report.psi.cwv.lcp_ms <= 4000
                ? "needs work"
                : "poor",
        note:
          report.psi.cwv.lcp_ms !== undefined && report.psi.cwv.lcp_ms <= 2500
            ? "Main content appears within the recommended window."
            : "This is the clearest signal of whether the page feels slow on first view.",
      },
      {
        label: "Interaction to Next Paint",
        current: formatMs(report.psi.cwv.inp_ms),
        target: "200 ms or less",
        status:
          report.psi.cwv.inp_ms === undefined
            ? "needs work"
            : report.psi.cwv.inp_ms <= 200
              ? "good"
              : report.psi.cwv.inp_ms <= 500
                ? "needs work"
                : "poor",
        note: "This tells you how responsive the page feels when users try to click or type.",
      },
      {
        label: "Cumulative Layout Shift",
        current: typeof report.psi.cwv.cls === "number" ? report.psi.cwv.cls.toFixed(2) : "-",
        target: "0.10 or less",
        status:
          report.psi.cwv.cls === undefined
            ? "needs work"
            : report.psi.cwv.cls <= 0.1
              ? "good"
              : report.psi.cwv.cls <= 0.25
                ? "needs work"
                : "poor",
        note: "High layout shift makes the page feel unstable and can cause missed clicks.",
      },
      {
        label: "Server response",
        current: formatMs(report.psi.cwv.ttfb_ms),
        target: "800 ms or less",
        status:
          report.psi.cwv.ttfb_ms === undefined
            ? "needs work"
            : report.psi.cwv.ttfb_ms <= 800
              ? "good"
              : report.psi.cwv.ttfb_ms <= 1800
                ? "needs work"
                : "poor",
        note: "Slow response time delays everything that comes after it.",
      },
      {
        label: "Performance score",
        current: `${report.summary.score100}/100`,
        target: "90 or higher",
        status:
          report.summary.score100 >= 90 ? "good" : report.summary.score100 >= 70 ? "needs work" : "poor",
        note: "This is the fastest way to gauge overall risk before reading the fixes.",
      },
    ]
  : [];

const summarySentences = report
  ? [
      report.summary.score100 >= 90
        ? `${report.canonicalHost} is performing well overall on ${report.device}, with a score of ${report.summary.score100}/100.`
        : report.summary.score100 >= 75
          ? `${report.canonicalHost} has a decent baseline on ${report.device}, but it is still slower than it should be in a few key places.`
          : report.summary.score100 >= 50
            ? `${report.canonicalHost} is noticeably slow on ${report.device}, with a score of ${report.summary.score100}/100.`
            : `${report.canonicalHost} is slow enough on ${report.device} to create a weak first impression and hurt conversions.`,
      report.psi.cwv.lcp_ms
        ? `Largest Contentful Paint is ${formatMs(report.psi.cwv.lcp_ms)}${report.psi.cwv.ttfb_ms ? ` and server response is ${formatMs(report.psi.cwv.ttfb_ms)}` : ""}.`
        : "The current scan shows meaningful delay in how quickly content becomes visible.",
      topIssueTitles.length > 0
        ? `The biggest contributors right now are ${joinWithAnd(topIssueTitles.slice(0, 3)).toLowerCase()}.`
        : "No major bottlenecks were detected in the current scan.",
      report.psi.cwv.status === "pass"
        ? "Core Web Vitals are passing, but tightening the highest-impact issues should make the experience feel smoother and more resilient."
        : "Core Web Vitals are failing, which means users are more likely to feel slow loading or lag before the page settles.",
    ]
  : [];

const kscore = report?.kscore;
const seoAnalysis = report?.seoAnalysis;
const imageAudit = report?.imageAudit;
const csrfToken = Astro.locals.csrfToken ?? "";
const stickyPrimaryHref = unlocked ? "/billing" : null;
const stickyPrimaryLabel = unlocked ? "Start monitoring" : "Unlock full report";
const secondaryCtaHref = report ? `/fix-it?reportId=${report.id}` : "/fix-it";
const secondaryCtaLabel = "Fix it for me";
const isExampleReport = report?.id === "example";

if (report) {
  await trackEvent({
    eventType: "report_viewed",
    scanId: isExampleReport ? null : report.id,
    reportId: isExampleReport ? null : report.id,
    userId: Astro.locals.user?.id ?? null,
    source: isExampleReport ? "report-example" : unlocked ? "report-unlocked" : previewUnlocked ? "report-preview" : "report-locked",
    referrer: Astro.request.headers.get("referer"),
    userAgent: Astro.request.headers.get("user-agent"),
    path: Astro.url.pathname,
    metadata: {
      previewUnlocked,
      unlocked,
      isExampleReport,
    },
  });
  if (isExampleReport) {
    await trackEvent({
      eventType: "example_report_viewed",
      userId: Astro.locals.user?.id ?? null,
      source: "report-example",
      referrer: Astro.request.headers.get("referer"),
      userAgent: Astro.request.headers.get("user-agent"),
      path: Astro.url.pathname,
      metadata: {
        previewUnlocked,
        unlocked,
      },
    });
  }
}
---
<BaseLayout title={title} description={description} noindex={noindex}>
  {jsonLd ? (
    <script slot="head" type="application/ld+json" is:inline>{JSON.stringify(jsonLd)}</script>
  ) : null}

  <section class="pt-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <Badge tone="info">Report</Badge>
        <h1 class="mt-3 text-3xl text-slate-100">{report ? report.url : "Generating report"}</h1>
        <p class="mt-2 text-sm text-slate-400">
          {report ? `Created ${new Date(report.createdAt).toLocaleString()}` : "This usually takes under 90 seconds."}
        </p>
      </div>
      <div class="flex items-center gap-3">
        {report && previewUnlocked ? (
          <Button href="#share" variant="ghost" size="sm" class="border-white/10">
            Share report
          </Button>
        ) : null}
        <Button href="/scan" variant="ghost" size="sm" class="border-white/10">
          Run another scan
        </Button>
      </div>
    </div>
  </section>

  {report && previewUnlocked ? (
    <>
      <section class="mt-8">
        <div class="grid gap-6 lg:grid-cols-[1.3fr_0.7fr]">
          <Card class="bg-gradient-to-br from-slate-900 via-slate-900 to-sky-950/40">
            <p class="text-xs uppercase tracking-[0.2em] text-sky-200/70">Summary</p>
            <h2 class="mt-3 text-3xl text-slate-100">
              {report.summary.score100 >= 90
                ? "Fast overall, with a few cleanup opportunities."
                : report.summary.score100 >= 75
                  ? "Solid foundation, but users still feel avoidable delay."
                  : report.summary.score100 >= 50
                    ? "The site is slower than it should be where it matters."
                    : "The site feels slow enough to cost attention and trust."}
            </h2>
            <div class="mt-5 space-y-3 text-sm leading-6 text-slate-300">
              {summarySentences.map((sentence) => (
                <p>{sentence}</p>
              ))}
            </div>
            <div class="mt-6 grid gap-3 sm:grid-cols-3">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Load time</p>
                <p class="mt-2 text-2xl text-slate-100">{formatMs(report.psi.cwv.lcp_ms)}</p>
                <p class="text-xs text-slate-400">Largest Contentful Paint</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Page weight</p>
                <p class="mt-2 text-2xl text-slate-100">{formatBytes(report.psi.audits.totalByteWeight)}</p>
                <p class="text-xs text-slate-400">Bytes loaded on the primary page</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Top issue</p>
                <p class="mt-2 text-base text-slate-100">{topIssueTitles[0] ?? "No major bottleneck detected"}</p>
                <p class="text-xs text-slate-400">Highest-priority place to start</p>
              </div>
            </div>
          </Card>

          <Card class="text-center">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Overall score</p>
            <div class="mt-4 flex justify-center">
              <ScoreDonut client:load score={report.summary.score100} />
            </div>
            <div class="mt-4 flex items-center justify-center gap-2">
              <span class="text-2xl text-slate-100">Grade {report.summary.grade}</span>
              <span class="text-sm text-slate-400">({report.summary.score100}/100)</span>
            </div>
            <div class="mt-6 grid gap-3 text-left">
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">CWV status</p>
                <p class={report.psi.cwv.status === "pass" ? "mt-2 text-emerald-200" : "mt-2 text-rose-200"}>
                  {report.psi.cwv.status === "pass" ? "Passing" : "Failing"}
                </p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Requests</p>
                <p class="mt-2 text-slate-100">{report.checks.page.requestCount ?? "-"}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Device</p>
                <p class="mt-2 text-slate-100">{titleCase(report.device)}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Detected stack</p>
                <p class="mt-2 text-slate-100">
                  {report.detectedStack.cmsGuess ?? report.detectedStack.frameworkGuess ?? "No strong match yet"}
                </p>
                <p class="mt-1 text-xs text-slate-400">
                  {report.detectedStack.hostingGuess ? `Hosting: ${report.detectedStack.hostingGuess}` : "Hosting signal still weak"}
                </p>
              </div>
            </div>
          </Card>
        </div>
      </section>

      <section class="mt-10">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Top problems</p>
            <h2 class="mt-2 text-2xl text-slate-100">Biggest issues slowing your site</h2>
            <p class="mt-2 text-sm text-slate-400">Start here before you worry about the long tail of smaller metrics.</p>
          </div>
        </div>
        <div class="mt-6 grid gap-4 lg:grid-cols-3">
          {topInsights.length > 0 ? (
            topInsights.map((insight, index) => (
              <Card>
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Problem {index + 1}</p>
                    <h3 class="mt-2 text-xl text-slate-100">{insight.title}</h3>
                  </div>
                  <span class={`rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] ${toneClass(insight.impact, "impact")}`}>
                    {insight.impact} impact
                  </span>
                </div>
                <p class="mt-4 text-sm leading-6 text-slate-300">{insight.whatItMeans}</p>
                <p class="mt-3 text-sm text-slate-400">{insight.whyItHurts}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  <span class={`rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] ${toneClass(insight.impact, "impact")}`}>
                    Impact: {insight.impact}
                  </span>
                  <span class={`rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] ${toneClass(insight.effort, "effort")}`}>
                    Difficulty: {insight.effort}
                  </span>
                  <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-slate-300">
                    {insight.severity}
                  </span>
                </div>
                <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Expected improvement</p>
                  <p class="mt-2 text-sm text-slate-200">{expectedImprovement(insight.category)}</p>
                </div>
              </Card>
            ))
          ) : (
            <Card class="lg:col-span-3">
              <p class="text-sm text-slate-300">No major problems were detected in the current scan.</p>
            </Card>
          )}
        </div>
      </section>

      <section class="mt-10">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Snapshot</p>
            <h2 class="mt-2 text-2xl text-slate-100">Visual performance snapshot</h2>
            <p class="mt-2 text-sm text-slate-400">
              Data source: {report.psi.source}{report.psi.message ? ` — ${report.psi.message}` : ""}
            </p>
          </div>
          <Badge tone={report.psi.cwv.status === "pass" ? "success" : "danger"}>
            {report.psi.cwv.status === "pass" ? "CWV pass" : "CWV fail"}
          </Badge>
        </div>
        <div class="mt-6 grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Load timeline</p>
            <h3 class="mt-2 text-xl text-slate-100">How the page unfolds in the browser</h3>
            <p class="mt-2 text-sm text-slate-400">TTFB, first paint, and largest paint show where users start to feel drag.</p>
            {timeline ? (
              <div class="mt-6 space-y-4">
                <div class="relative h-3 rounded-full bg-white/10">
                  <span
                    class="absolute left-0 h-3 rounded-full bg-emerald-400/20"
                    style={`width: ${timelinePct(timeline.fcp)}%`}
                  ></span>
                  <span
                    class="absolute left-0 h-3 rounded-full bg-sky-400/20"
                    style={`width: ${timelinePct(timeline.lcp)}%`}
                  ></span>
                  <span
                    class="absolute -top-2 h-7 w-1 rounded-full bg-amber-300"
                    style={`left: ${timelinePct(timeline.ttfb)}%`}
                  ></span>
                  <span
                    class="absolute -top-2 h-7 w-1 rounded-full bg-emerald-300"
                    style={`left: ${timelinePct(timeline.fcp)}%`}
                  ></span>
                  <span
                    class="absolute -top-2 h-7 w-1 rounded-full bg-sky-300"
                    style={`left: ${timelinePct(timeline.lcp)}%`}
                  ></span>
                </div>
                <div class="grid gap-3 md:grid-cols-2">
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">TTFB</p>
                    <p class="mt-2 text-slate-100">{formatMs(report.psi.cwv.ttfb_ms)}</p>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">FCP</p>
                    <p class="mt-2 text-slate-100">{formatMs(report.psi.cwv.fcp_ms)}</p>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">LCP</p>
                    <p class="mt-2 text-slate-100">{formatMs(report.psi.cwv.lcp_ms)}</p>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Page weight</p>
                    <p class="mt-2 text-slate-100">{formatBytes(report.psi.audits.totalByteWeight)}</p>
                  </div>
                </div>
              </div>
            ) : null}
          </Card>

          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Metrics</p>
            <h3 class="mt-2 text-xl text-slate-100">Performance overview</h3>
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">INP</p>
                <p class="mt-2 text-slate-100">{formatMs(report.psi.cwv.inp_ms)}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">CLS</p>
                <p class="mt-2 text-slate-100">{typeof report.psi.cwv.cls === "number" ? report.psi.cwv.cls.toFixed(2) : "-"}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">JS weight</p>
                <p class="mt-2 text-slate-100">
                  {report.checks.page.jsKb !== undefined ? `${report.checks.page.jsKb} KB` : "-"}
                </p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
