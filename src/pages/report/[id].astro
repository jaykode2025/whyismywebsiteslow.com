---
/**
 * REDESIGNED REPORT PAGE — BUSINESS-FIRST LAYOUT
 * 
 * Changes from original:
 * 1. Business impact moves ABOVE the fold (not buried mid-page)
 * 2. Proof block with real-user metrics prominently displayed
 * 3. Clearer visual hierarchy: Problem → Impact → Proof → Fixes → CTA
 * 4. Enhanced scanner data (CrUX) displayed when available
 * 5. Confidence indicators show data reliability
 * 6. Simplified above-fold summary (3 key metrics max)
 * 7. Stronger, more frequent CTAs tied to business outcomes
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import ScoreDonut from "../../components/ScoreDonut.svelte";
import ReportFilters from "../../components/ReportFilters.svelte";
import ScanProgress from "../../components/ScanProgress.svelte";
import ShareActions from "../../components/ShareActions.svelte";
import LockedOverlay from "../../components/LockedOverlay.astro";
import TextToSpeech from "../../components/ui/TextToSpeech.svelte";
import ReportCharts from "../../components/seo/ReportCharts.svelte";
import { loadStoredReport } from "../../lib/reports";
import { exampleReport } from "../../lib/example";
import { isReportUnlocked } from "../../lib/entitlements";
import { hasLeadAccess, LEAD_ACCESS_COOKIE_NAME } from "../../lib/leadAccess";
import { trackEvent } from "../../lib/analytics";

const { id } = Astro.params;
const stored = id === "example" ? { status: "done", report: exampleReport() } : await loadStoredReport(id ?? "", Astro.locals);
const report = stored?.report;
const unlocked = report ? (report.id === "example" ? true : await isReportUnlocked(report.id, Astro.locals)) : false;
const leadAccessCookie = Astro.cookies.get(LEAD_ACCESS_COOKIE_NAME)?.value;
const previewUnlocked = report ? unlocked || hasLeadAccess(leadAccessCookie, report.id) : false;

const title = report
  ? `Why is ${report.canonicalHost} slow? Report + Fixes`
  : "Report in progress";
const description = report
  ? `Performance report for ${report.canonicalHost} with grade ${report.summary.grade} and top fixes.`
  : "We are generating your performance report.";

const noindex = !report || report.visibility !== "public";
const jsonLd = report
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `Why is ${report.canonicalHost} slow?`,
      description,
      url: `${Astro.site?.origin ?? Astro.url.origin}/report/${report.id}`,
      isPartOf: {
        "@type": "SoftwareApplication",
        name: "whyismywebsiteslow",
        applicationCategory: "DeveloperApplication",
        operatingSystem: "Web",
      },
    }
  : null;

// Formatting helpers
const formatMs = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  return value >= 1000 ? `${(value / 1000).toFixed(1)}s` : `${Math.round(value)} ms`;
};

const formatBytes = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  const mb = value / 1_000_000;
  return mb >= 1 ? `${mb.toFixed(2)} MB` : `${Math.round(value / 1000)} KB`;
};

const formatPercent = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  return `${value.toFixed(2)}%`;
};

const titleCase = (value: string) =>
  value
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

// Enhanced scanner data (real-user metrics from CrUX)
const hasRumData = report?.psi?.rum && report.psi.rum.confidence !== "low";
const rumConfidence = report?.psi?.rum?.confidence;
const rumSampleSize = report?.psi?.rum?.sampleSize ?? 0;
const overallGrade = report?.psi?.grade ?? report?.summary?.grade;
const overallScore = report?.psi?.overallScore ?? report?.summary?.score100;

// Business impact first messaging
const businessHeadline = report
  ? report.summary.score100 >= 90
    ? "Your site is fast enough to not lose money — but there's still upside."
    : report.summary.score100 >= 75
      ? "Your site is leaving conversions on the table due to avoidable delays."
      : report.summary.score100 >= 50
        ? "Your site is slow enough to noticeably hurt trust, leads, and revenue."
        : "Your site is costing you customers right now."
  : "";

const topInsights = report
  ? [...report.insights]
      .sort((a, b) => {
        const impactRank = { high: 3, medium: 2, low: 1 };
        const severityRank = { critical: 4, high: 3, medium: 2, low: 1 };
        return impactRank[b.impact] - impactRank[a.impact] || severityRank[b.severity] - severityRank[a.severity];
      })
      .slice(0, 3)
  : [];

const csrfToken = Astro.locals.csrfToken ?? "";
const isExampleReport = report?.id === "example";

// Track view
if (report) {
  await trackEvent({
    eventType: "report_viewed",
    scanId: isExampleReport ? null : report.id,
    reportId: isExampleReport ? null : report.id,
    userId: Astro.locals.user?.id ?? null,
    source: isExampleReport ? "report-example" : unlocked ? "report-unlocked" : previewUnlocked ? "report-preview" : "report-locked",
    referrer: Astro.request.headers.get("referer"),
    userAgent: Astro.request.headers.get("user-agent"),
    path: Astro.url.pathname,
    metadata: { previewUnlocked, unlocked, isExampleReport },
  });
}
---

<BaseLayout title={title} description={description} noindex={noindex}>
  {jsonLd ? (
    <script slot="head" type="application/ld+json" is:inline>{JSON.stringify(jsonLd)}</script>
  ) : null}

  <!-- HEADER -->
  <section class="pt-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <Badge tone="info">Performance Report</Badge>
        <h1 class="mt-3 text-3xl text-slate-100">{report ? report.canonicalHost : "Generating report"}</h1>
        <p class="mt-2 text-sm text-slate-400">
          {report ? `Scanned on ${new Date(report.createdAt).toLocaleDateString()} • ${titleCase(report.device)}` : "This usually takes under 90 seconds."}
        </p>
      </div>
      <div class="flex items-center gap-3">
        {report && previewUnlocked ? (
          <Button href="#share" variant="ghost" size="sm" class="border-white/10">
            Share
          </Button>
        ) : null}
        <Button href="/scan" variant="ghost" size="sm" class="border-white/10">
          New Scan
        </Button>
      </div>
    </div>
  </section>

  {report && previewUnlocked ? (
    <>
      <!-- ABOVE THE FOLD: BUSINESS IMPACT + PROOF -->
      <section class="mt-8">
        <div class="grid gap-6 lg:grid-cols-[1.4fr_0.6fr]">
          <!-- LEFT: Business Impact & Key Metrics -->
          <Card class="relative overflow-hidden">
            <!-- Background gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-900 to-sky-950/30"></div>
            
            <div class="relative">
              <!-- Headline: Business-first -->
              <p class="text-xs uppercase tracking-[0.2em] text-sky-200/70">Diagnosis</p>
              <h2 class="mt-3 text-3xl font-bold text-slate-100">{businessHeadline}</h2>
              
              <!-- Real-user data badge (if available) -->
              {hasRumData ? (
                <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-1">
                  <span class="text-xs font-semibold text-emerald-200">✓ Real-user data</span>
                  <span class="text-[10px] text-emerald-300/80">
                    {rumConfidence === "high" ? `High confidence (${rumSampleSize.toLocaleString()} samples)` : `Medium confidence (${rumSampleSize.toLocaleString()} samples)`}
                  </span>
                </div>
              ) : report?.psi?.sources?.rumAvailable === false ? (
                <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1">
                  <span class="text-xs font-semibold text-amber-200">⚠ Lab data only</span>
                  <span class="text-[10px] text-amber-300/80">No real-user data available for this domain yet</span>
                </div>
              ) : null}
              
              <!-- Key Metrics: 3-column grid -->
              <div class="mt-6 grid gap-4 sm:grid-cols-3">
                <!-- Metric 1: Overall Grade -->
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                  <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Overall Grade</p>
                  <div class="mt-2 flex items-baseline gap-2">
                    <span class="text-4xl font-bold text-slate-100">{overallGrade}</span>
                    <span class="text-sm text-slate-400">{overallScore}/100</span>
                  </div>
                  {hasRumData ? (
                    <p class="mt-2 text-[11px] text-emerald-300/80">Weighted 60% on real users</p>
                  ) : (
                    <p class="mt-2 text-[11px] text-slate-500">Based on lab simulation</p>
                  )}
                </div>
                
                <!-- Metric 2: Load Time -->
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                  <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Load Time</p>
                  <p class="mt-2 text-3xl font-bold text-slate-100">{formatMs(report.psi.cwv.lcp_ms)}</p>
                  <p class="mt-2 text-[11px] text-slate-500">Largest Contentful Paint</p>
                  {report.psi.cwv.lcp_ms && report.psi.cwv.lcp_ms > 2500 ? (
                    <p class="mt-1 text-[10px] text-rose-300">Above 2.5s threshold</p>
                  ) : (
                    <p class="mt-1 text-[10px] text-emerald-300">Within recommended</p>
                  )}
                </div>
                
                <!-- Metric 3: Business Impact -->
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                  <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Estimated Impact</p>
                  <p class="mt-2 text-2xl font-bold text-slate-100">{report.businessImpact.estimatedRange.conversionLiftPct}</p>
                  <p class="mt-2 text-[11px] text-slate-500">Potential conversion lift</p>
                  <p class="mt-1 text-[10px] text-slate-400">{report.businessImpact.estimatedRange.leadRecoveryPct} lead recovery</p>
                </div>
              </div>
              
              <!-- CWV Status Badge -->
              <div class="mt-6 flex items-center gap-3">
                <Badge tone={report.psi.cwv.status === "pass" ? "success" : "danger"}>
                  {report.psi.cwv.status === "pass" ? "✓ Core Web Vitals Passing" : "✗ Core Web Vitals Failing"}
                </Badge>
                {hasRumData && report.psi.rum.status === "pass" ? (
                  <Badge tone="success">✓ Real-user metrics healthy</Badge>
                ) : hasRumData && report.psi.rum.status === "fail" ? (
                  <Badge tone="danger">⚠ Real users experiencing issues</Badge>
                ) : null}
              </div>
            </div>
          </Card>
          
          <!-- RIGHT: Score + Quick Stats -->
          <Card class="text-center">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Overall Score</p>
            <div class="mt-4 flex justify-center">
              <ScoreDonut client:load score={overallScore} />
            </div>
            <div class="mt-4 flex items-center justify-center gap-2">
              <span class="text-2xl text-slate-100">Grade {overallGrade}</span>
              <span class="text-sm text-slate-400">({overallScore}/100)</span>
            </div>
            
            <!-- Quick Stats -->
            <div class="mt-6 space-y-3 text-left">
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Page Weight</p>
                <p class="mt-2 text-lg text-slate-100">{formatBytes(report.psi.audits.totalByteWeight)}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Requests</p>
                <p class="mt-2 text-lg text-slate-100">{report.checks.page.requestCount ?? "-"}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Detected Stack</p>
                <p class="mt-2 text-lg text-slate-100">
                  {report.detectedStack.cmsGuess ?? report.detectedStack.frameworkGuess ?? "Unknown"}
                </p>
                {report.detectedStack.hostingGuess ? (
                  <p class="mt-1 text-xs text-slate-400">Hosting: {report.detectedStack.hostingGuess}</p>
                ) : null}
              </div>
            </div>
          </Card>
        </div>
      </section>

      <!-- PROOF BLOCK: Real-User vs Lab Comparison -->
      {hasRumData ? (
        <section class="mt-10">
          <div class="flex items-end justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Proof</p>
              <h2 class="mt-2 text-2xl text-slate-100">Real users experience this</h2>
              <p class="mt-2 text-sm text-slate-400">
                Data from {rumSampleSize.toLocaleString()} Chrome users • {rumConfidence} confidence
              </p>
            </div>
          </div>
          
          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            <!-- Real-User Metrics -->
            <Card>
              <div class="flex items-center justify-between">
                <p class="text-xs uppercase tracking-[0.2em] text-emerald-300/70">Real-User Metrics</p>
                <Badge tone="success">CrUX Data</Badge>
              </div>
              <div class="mt-4 space-y-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-300">Largest Contentful Paint</p>
                    <p class="text-xs text-slate-500">When main content appears</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-slate-100">{formatMs(report.psi.rum.lcp_ms)}</p>
                    {report.psi.rum.lcp_ms <= 2500 ? (
                      <p class="text-[11px] text-emerald-300">✓ Good</p>
                    ) : (
                      <p class="text-[11px] text-rose-300">⚠ Slow</p>
                    )}
                  </div>
                </div>
                
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-300">Interaction to Next Paint</p>
                    <p class="text-xs text-slate-500">Responsiveness to clicks</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-slate-100">{formatMs(report.psi.rum.inp_ms)}</p>
                    {report.psi.rum.inp_ms <= 200 ? (
                      <p class="text-[11px] text-emerald-300">✓ Good</p>
                    ) : (
                      <p class="text-[11px] text-rose-300">⚠ Slow</p>
                    )}
                  </div>
                </div>
                
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-300">Cumulative Layout Shift</p>
                    <p class="text-xs text-slate-500">Visual stability</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-slate-100">{report.psi.rum.cls.toFixed(2)}</p>
                    {report.psi.rum.cls <= 0.1 ? (
                      <p class="text-[11px] text-emerald-300">✓ Good</p>
                    ) : (
                      <p class="text-[11px] text-rose-300">⚠ Unstable</p>
                    )}
                  </div>
                </div>
              </div>
            </Card>
            
            <!-- Lab Metrics -->
            <Card>
              <div class="flex items-center justify-between">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Lab Metrics</p>
                <Badge tone="info">Lighthouse</Badge>
              </div>
              <div class="mt-4 space-y-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-300">Largest Contentful Paint</p>
                    <p class="text-xs text-slate-500">Controlled test environment</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-slate-100">{formatMs(report.psi.cwv.lcp_ms)}</p>
                  </div>
                </div>
                
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-300">Server Response Time</p>
                    <p class="text-xs text-slate-500">Time to first byte</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-slate-100">{formatMs(report.psi.cwv.ttfb_ms)}</p>
                  </div>
                </div>
                
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm text-slate-300">Total Page Weight</p>
                    <p class="text-xs text-slate-500">All resources combined</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-slate-100">{formatBytes(report.psi.audits.totalByteWeight)}</p>
                  </div>
                </div>
              </div>
            </Card>
          </div>
          
          {report.psi.network && report.psi.network.ttfb_ms ? (
            <div class="mt-6">
              <Card>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Network Timing</p>
                <div class="mt-4 grid gap-4 sm:grid-cols-3">
                  <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Direct TTFB</p>
                    <p class="mt-2 text-2xl text-slate-100">{formatMs(report.psi.network.ttfb_ms)}</p>
                    <p class="mt-1 text-xs text-slate-400">Measured from our scan</p>
                  </div>
                  {report.psi.network.redirect_count && report.psi.network.redirect_count > 0 ? (
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                      <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Redirects</p>
                      <p class="mt-2 text-2xl text-slate-100">{report.psi.network.redirect_count}</p>
                      <p class="mt-1 text-xs text-slate-400">Adding {formatMs(report.psi.network.redirect_time_ms)} delay</p>
                    </div>
                  ) : null}
                  <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Data Source</p>
                    <p class="mt-2 text-lg text-slate-100">
                      {report.psi.sources?.rumAvailable ? "CrUX + PSI + Network" : "PSI + Network"}
                    </p>
                    <p class="mt-1 text-xs text-slate-400">Multi-source verification</p>
                  </div>
                </div>
              </Card>
            </div>
          ) : null}
        </section>
      ) : null}

      <!-- TOP PROBLEMS -->
      <section class="mt-10">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Top Problems</p>
            <h2 class="mt-2 text-2xl text-slate-100">Biggest issues costing you performance</h2>
            <p class="mt-2 text-sm text-slate-400">Fix these first — they have the highest business impact.</p>
          </div>
        </div>
        
        <div class="mt-6 grid gap-4 lg:grid-cols-3">
          {topInsights.length > 0 ? (
            topInsights.map((insight, index) => (
              <Card>
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Problem {index + 1}</p>
                    <h3 class="mt-2 text-xl text-slate-100">{insight.title}</h3>
                  </div>
                  <span class={`rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] ${
                    insight.impact === "high" ? "border-rose-400/30 bg-rose-400/10 text-rose-200" :
                    insight.impact === "medium" ? "border-amber-400/30 bg-amber-400/10 text-amber-200" :
                    "border-emerald-400/30 bg-emerald-400/10 text-emerald-200"
                  }`}>
                    {insight.impact}
                  </span>
                </div>
                <p class="mt-4 text-sm leading-6 text-slate-300">{insight.whatItMeans}</p>
                <p class="mt-3 text-sm text-slate-400">{insight.whyItHurts}</p>
                <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Expected improvement</p>
                  <p class="mt-2 text-sm text-slate-200">
                    {insight.category === "server" || insight.category === "cdn"
                      ? `Could bring server response down from ${formatMs(report.psi.cwv.ttfb_ms)} toward recommended times.`
                      : insight.category === "images"
                        ? "Should cut page weight and improve visual load."
                        : "Should reduce load friction and improve user experience."}
                  </p>
                </div>
              </Card>
            ))
          ) : (
            <Card class="lg:col-span-3">
              <p class="text-sm text-slate-300">No major problems detected.</p>
            </Card>
          )}
        </div>
      </section>

      <!-- BUSINESS IMPACT -->
      <section class="mt-10">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Business Impact</p>
            <h2 class="mt-2 text-2xl text-slate-100">Why this matters beyond scores</h2>
            <p class="mt-2 text-sm text-slate-400">{report.businessImpact.headline}</p>
          </div>
          <Badge tone={report.businessImpact.riskLevel === "high" ? "danger" : report.businessImpact.riskLevel === "medium" ? "warning" : "success"}>
            {report.businessImpact.riskLevel} risk
          </Badge>
        </div>
        
        <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_0.9fr]">
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Business Risks</p>
            <ul class="mt-4 space-y-3 text-sm text-slate-200">
              {report.businessImpact.bullets.map((bullet) => (
                <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{bullet}</li>
              ))}
            </ul>
          </Card>
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Modeled Upside</p>
            <div class="mt-4 grid gap-3">
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Conversion Lift</p>
                <p class="mt-2 text-2xl text-slate-100">{report.businessImpact.estimatedRange.conversionLiftPct}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Lead Recovery</p>
                <p class="mt-2 text-2xl text-slate-100">{report.businessImpact.estimatedRange.leadRecoveryPct}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Revenue Protection</p>
                <p class="mt-2 text-2xl text-slate-100">{report.businessImpact.estimatedRange.revenueProtection}</p>
              </div>
            </div>
            <p class="mt-4 text-xs text-slate-500">
              Modeled from current scan risk and common speed-to-conversion patterns. Use as prioritization aid, not financial advice.
            </p>
          </Card>
        </div>
      </section>

      <!-- FIX GUIDE -->
      <section class="mt-10">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Fix Guide</p>
            <h2 class="mt-2 text-2xl text-slate-100">What to fix first</h2>
            <p class="mt-2 text-sm text-slate-400">Start with quick wins, then tackle high-leverage fixes.</p>
          </div>
        </div>
        
        <div class="mt-6 grid gap-4 lg:grid-cols-3">
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Quick Wins</p>
            <ul class="mt-4 space-y-2 text-sm text-slate-200">
              {report.recommendationSummary.quickWins.length > 0 ? (
                report.recommendationSummary.quickWins.map((item) => (
                  <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{item}</li>
                ))
              ) : (
                <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">No low-effort wins detected.</li>
              )}
            </ul>
          </Card>
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Highest Leverage</p>
            <ul class="mt-4 space-y-2 text-sm text-slate-200">
              {report.recommendationSummary.highestLeverageFixes.map((item) => (
                <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{item}</li>
              ))}
            </ul>
          </Card>
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Next Step</p>
            <div class="mt-4 rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-lg text-slate-100">
                {report.recommendationSummary.nextBestAction === "start-monitoring"
                  ? "Monitoring will protect your gains once fixes ship."
                  : report.recommendationSummary.nextBestAction === "request-service"
                    ? "This looks valuable enough to justify hands-on help."
                    : "Unlock the detailed report to sequence the work."}
              </p>
              <p class="mt-3 text-sm text-slate-400">
                Recommended based on score, CWV status, and effort vs. impact.
              </p>
            </div>
          </Card>
        </div>
      </section>

      <!-- FINAL CTA -->
      <section class="mt-10">
        <Card id="share" class={unlocked ? "border-emerald-500/20 bg-emerald-500/5" : "bg-gradient-to-r from-slate-950/70 via-slate-900/70 to-slate-950/70"}>
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Next Step</p>
              <h2 class="mt-2 text-2xl text-slate-100">
                {unlocked
                  ? "Keep this site healthy after fixes ship."
                  : "Turn this diagnosis into a full remediation plan."}
              </h2>
              <p class="mt-2 text-sm text-slate-300">
                {unlocked
                  ? "Weekly regressions, alerts, and trend tracking."
                  : "Unlock the detailed checklist, priority order, and implementation guidance."}
              </p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
              {unlocked ? (
                <Button href="/billing" size="lg" class="rounded-xl bg-emerald-500 text-slate-950 hover:bg-emerald-400 border-none">
                  Start Monitoring
                </Button>
              ) : (
                <>
                  <form method="post" action="/api/billing/report-checkout">
                    <input type="hidden" name="reportId" value={report.id} />
                    <input type="hidden" name="_csrf" value={csrfToken} />
                    <input type="hidden" name="offerContext" value="report-final-cta" />
                    <Button type="submit" size="lg" class="w-full rounded-xl">
                      Unlock Full Report — $19
                    </Button>
                  </form>
                  <Button href="/billing" variant="ghost" size="lg" class="rounded-xl border-white/10">
                    Monitor Weekly — $12/mo
                  </Button>
                </>
              )}
              <Button href={`/fix-it?reportId=${report.id}`} variant="ghost" size="lg" class="rounded-xl border-white/10">
                Fix It For Me
              </Button>
            </div>
          </div>
          <div class="mt-6">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Share</p>
            <div class="mt-3">
              <ShareActions client:load url={(Astro.site?.origin ?? Astro.url.origin) + `/report/${report.id}`} title={title} />
            </div>
          </div>
        </Card>
      </section>
    </>
  ) : report ? (
    <!-- LOCKED / PREVIEW STATE -->
    <section class="mt-10">
      <Card>
        <h2 class="text-2xl text-slate-100">Get the preview by email</h2>
        <p class="mt-2 text-slate-300">
          Enter your email to unlock this report preview, then decide if you want the full paid unlock.
        </p>
        <form method="post" action="/api/leads/preview" class="mt-4 flex flex-col gap-3 sm:flex-row">
          <input type="hidden" name="reportId" value={report.id} />
          <input type="hidden" name="source" value="report-preview-gate" />
          <input type="email" name="email" required placeholder="you@company.com" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500" />
          <button type="submit" class="rounded-xl border border-emerald-300/40 bg-emerald-500/20 px-4 py-3 text-sm font-semibold text-emerald-100 hover:bg-emerald-500/30">
            Unlock Preview
          </button>
        </form>
        <form method="post" action="/api/billing/report-checkout" class="mt-4">
          <input type="hidden" name="reportId" value={report.id} />
          <input type="hidden" name="_csrf" value={csrfToken} />
          <button type="submit" class="rounded-xl bg-sky-500 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-400">
            Unlock Full Report - $19
          </button>
        </form>
      </Card>
    </section>
  ) : (
    <!-- LOADING STATE -->
    <section class="mt-10">
      <Card>
        <h2 class="text-2xl text-slate-100">Report in progress</h2>
        <p class="mt-2 text-slate-300">We are running a scan and building your report.</p>
        <div class="mt-4">
          <ScanProgress client:load id={id} />
        </div>
      </Card>
    </section>
  )}

  {report ? <div class="h-28" aria-hidden="true"></div> : null}
</BaseLayout>
