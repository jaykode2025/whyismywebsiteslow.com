---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import ScoreDonut from "../../components/ScoreDonut.svelte";
import ReportFilters from "../../components/ReportFilters.svelte";
import ScanProgress from "../../components/ScanProgress.svelte";
import ShareActions from "../../components/ShareActions.svelte";
import LockedOverlay from "../../components/LockedOverlay.astro";
import { loadStoredReport } from "../../lib/reports";
import { exampleReport } from "../../lib/example";
import { isReportUnlocked } from "../../lib/entitlements";

const { id } = Astro.params;
const stored = id === "example" ? { status: "done", report: exampleReport() } : await loadStoredReport(id ?? "", Astro.locals);
const report = stored?.report;
const unlocked = report ? (report.id === "example" ? true : await isReportUnlocked(report.id, Astro.locals)) : false;

const title = report
  ? `Why is ${report.canonicalHost} slow? Report + Fixes`
  : "Report in progress";
const description = report
  ? `Performance report for ${report.canonicalHost} with grade ${report.summary.grade} and top fixes.`
  : "We are generating your performance report.";

const noindex = !report || report.visibility !== "public";
const jsonLd = report
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `Why is ${report.canonicalHost} slow?`,
      description,
      url: `${Astro.site?.origin ?? Astro.url.origin}/report/${report.id}`,
      isPartOf: {
        "@type": "SoftwareApplication",
        name: "whyismywebsiteslow",
        applicationCategory: "DeveloperApplication",
        operatingSystem: "Web",
      },
    }
  : null;

const formatMs = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  return value >= 1000 ? `${(value / 1000).toFixed(1)}s` : `${Math.round(value)} ms`;
};

const formatBytes = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  const mb = value / 1_000_000;
  return mb >= 1 ? `${mb.toFixed(2)} MB` : `${Math.round(value / 1000)} KB`;
};

const timeline = report
  ? {
      ttfb: report.psi.cwv.ttfb_ms ?? 0,
      fcp: report.psi.cwv.fcp_ms ?? 0,
      lcp: report.psi.cwv.lcp_ms ?? 0,
    }
  : null;

const timelineMax = timeline ? Math.max(timeline.ttfb, timeline.fcp, timeline.lcp, 1) : 1;
const timelinePct = (value: number) => Math.min(100, (value / timelineMax) * 100);

const groupedInsights = report && unlocked
  ? Object.entries(
      report.insights.reduce((acc, insight) => {
        const key = insight.category;
        acc[key] = acc[key] ?? [];
        acc[key].push(insight);
        return acc;
      }, {} as Record<string, typeof report.insights>)
    )
  : [];

const scoreDrivers = report
  ? [
      report.psi.cwv.status === "fail" ? "CWV fail (-15)" : null,
      report.psi.cwv.ttfb_ms && report.psi.cwv.ttfb_ms > 800 ? "TTFB > 800ms (-10)" : null,
      report.psi.audits.totalByteWeight && report.psi.audits.totalByteWeight > 3_000_000
        ? "Total weight > 3MB (-10)"
        : null,
    ].filter(Boolean)
  : [];

const kscore = report?.kscore;
const kscoreCategories = kscore ? Object.entries(kscore.categories) : [];
const seoAnalysis = report?.seoAnalysis;
const imageAudit = report?.imageAudit;
const topIssue = report?.summary.topIssues?.[0] ?? "No major bottlenecks detected.";

const formatPercent = (value?: number) => {
  if (value === undefined || value === null || Number.isNaN(value)) return "-";
  return `${value.toFixed(2)}%`;
};
---
<BaseLayout title={title} description={description} noindex={noindex}>
  {jsonLd ? (
    <script slot="head" type="application/ld+json" is:inline>{JSON.stringify(jsonLd)}</script>
  ) : null}
  <section class="pt-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <Badge tone="info">Report</Badge>
          <h1 class="mt-3 text-3xl text-slate-100">{report ? report.url : "Generating report"}</h1>
          <p class="mt-2 text-sm text-slate-400">
            {report ? `Created ${new Date(report.createdAt).toLocaleString()}` : "This usually takes under 90 seconds."}
          </p>
        </div>
      <div class="flex items-center gap-3">
        <Button href="/scan" variant="ghost" size="sm" class="border-white/10">
          Run another scan
        </Button>
      </div>
    </div>
  </section>

  {report ? (
    <section class="mt-6">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
        <div class="grid gap-4 md:grid-cols-[0.9fr_0.8fr_1.6fr_auto] md:items-center">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Score</p>
            <p class="mt-2 text-2xl text-slate-100">{report.summary.score100}/100</p>
            <p class="text-xs text-slate-400">Grade {report.summary.grade}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">CWV status</p>
            <p class={report.psi.cwv.status === "pass" ? "mt-2 text-emerald-200" : "mt-2 text-rose-200"}>
              {report.psi.cwv.status}
            </p>
            <p class="text-xs text-slate-400">LCP {formatMs(report.psi.cwv.lcp_ms)}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Top issue</p>
            <p class="mt-2 text-sm text-slate-200">{topIssue}</p>
            <p class="text-xs text-slate-500">Prioritized in the fixes below.</p>
          </div>
          <div class="flex md:justify-end">
            <Button href="#share" variant="ghost" size="sm" class="rounded-xl border-white/10">
              Share report
            </Button>
          </div>
        </div>
      </div>
    </section>
  ) : null}

  {report && !unlocked ? (
    <section class="mt-6">
      <div class="rounded-2xl border border-white/10 bg-gradient-to-r from-slate-950/70 via-slate-900/70 to-slate-950/70 p-5">
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Report locked</p>
            <p class="mt-2 text-sm text-slate-200">
              Unlock to see prioritized fixes, exact steps, and the full checklist.
            </p>
            <p class="mt-1 text-xs text-slate-400">One-time payment • Instant access • No account required</p>
          </div>
          <form method="post" action="/api/billing/report-checkout">
            <input type="hidden" name="reportId" value={report.id} />
            <Button type="submit" size="lg" class="w-full rounded-xl">
              Unlock Full Report — $19
            </Button>
          </form>
        </div>
          <div class="grid gap-3 md:grid-cols-2">
            <div class="rounded-xl border border-white/10 bg-white/5 p-3">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Estimated impact if fixed</p>
              <ul class="mt-2 space-y-1 text-xs text-slate-300">
                <li>+12–28% higher conversion rate (mobile)</li>
                <li>−0.8s LCP → lower bounce</li>
                <li>Potential uplift: $320–$1,900/month</li>
              </ul>
              <p class="mt-2 text-[11px] text-slate-500">Modeled from industry benchmarks; ranges vary by site.</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-3">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">What this unlocks</p>
              <ul class="mt-2 space-y-1 text-xs text-slate-300">
                <li>Exact fixes, not generic advice</li>
                <li>Priority order (what to fix first)</li>
                <li>Dev-ready steps and benchmarks</li>
                <li>Before/after checklist to verify wins</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : null}

  {report && unlocked ? (
    <section class="mt-6">
      <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/5 p-5">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-sm text-emerald-100">Want to keep this site fast forever?</p>
            <p class="mt-1 text-xs text-emerald-200/60">Upgrade to Pro for 24/7 monitoring, weekly reports, and instant alerts.</p>
          </div>
          <Button href="/billing" size="sm" class="rounded-xl bg-emerald-500 hover:bg-emerald-400 text-slate-950 border-none">
            Get 24/7 Monitoring — $99/mo
          </Button>
        </div>
      </div>
    </section>
  ) : null}

  {report ? (
    <section class="mt-10 grid gap-6 lg:grid-cols-[0.35fr_0.65fr]">
      <div class="space-y-6">
        <Card class="text-center">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Overall score</p>
          <div class="mt-4 flex justify-center">
            <ScoreDonut client:load score={report.summary.score100} />
          </div>
          <div class="mt-4 flex items-center justify-center gap-2">
            <span class="text-2xl text-slate-100">Grade {report.summary.grade}</span>
            <span class="text-sm text-slate-400">({report.summary.score100}/100)</span>
          </div>
        </Card>
        {kscore ? (
          <Card>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">K-Score</p>
            <div class="mt-4 flex items-center justify-between">
              <div>
                <p class="text-3xl text-slate-100">{kscore.overall}</p>
                <p class="text-sm text-slate-400">Grade {kscore.grade}</p>
              </div>
              <div class="h-20 w-20">
                <ScoreDonut client:load score={kscore.overall} />
              </div>
            </div>
            <div class="mt-4">
              {unlocked ? (
                <ul class="space-y-2 text-sm text-slate-200">
                  {kscoreCategories.map(([name, data]) => (
                    <li class="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-3 py-2">
                      <span class="capitalize text-slate-300">{name}</span>
                      <span class={data.status === "good" ? "text-emerald-200" : data.status === "ok" ? "text-amber-200" : "text-rose-200"}>
                        {data.score}
                      </span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-xs text-slate-400">Unlock to see the K-Score category breakdown.</p>
              )}
            </div>
          </Card>
        ) : null}
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Score drivers</p>
          <p class="mt-2 text-sm text-slate-300">These factors have the biggest impact on the grade.</p>
          <ul class="mt-4 space-y-2 text-sm text-slate-200">
            {scoreDrivers.length > 0 ? (
              scoreDrivers.map((driver) => (
                <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">{driver}</li>
              ))
            ) : (
              <li class="rounded-xl border border-emerald-300/30 bg-emerald-300/10 px-3 py-2 text-emerald-100">
                No major penalties detected.
              </li>
            )}
          </ul>
        </Card>
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Core Web Vitals</p>
          <div class="mt-3 flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm">
            <span class="text-slate-300">CWV status</span>
            <span class={report.psi.cwv.status === "pass" ? "text-emerald-200" : "text-rose-200"}>
              {report.psi.cwv.status}
            </span>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-4 text-sm text-slate-200">
            <div>
              <p class="text-xs uppercase tracking-[0.12em] text-slate-500">LCP</p>
              <p>{formatMs(report.psi.cwv.lcp_ms)}</p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.12em] text-slate-500">INP</p>
              <p>{formatMs(report.psi.cwv.inp_ms)}</p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.12em] text-slate-500">CLS</p>
              <p>{typeof report.psi.cwv.cls === "number" ? report.psi.cwv.cls.toFixed(2) : "-"}</p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Status</p>
              <p class={report.psi.cwv.status === "pass" ? "text-emerald-200" : "text-rose-200"}>
                {report.psi.cwv.status}
              </p>
            </div>
          </div>
        </Card>
        <Card id="share">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Share & embed</p>
          <p class="mt-2 text-sm text-slate-300">Use a direct link or embed this report.</p>
          <div class="mt-4">
            <ShareActions
              client:load
              url={(Astro.site?.origin ?? Astro.url.origin) + `/report/${report.id}`}
              title={title}
            />
          </div>
        </Card>
      </div>
      <div class="space-y-6">
        <Card>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Score categories</p>
              <h2 class="mt-2 text-2xl text-slate-100">Performance breakdown</h2>
              <p class="mt-1 text-xs text-slate-500">Data source: {report.psi.source}{report.psi.message ? ` — ${report.psi.message}` : ""}</p>
            </div>
            <Badge tone={report.psi.cwv.status === "pass" ? "success" : "danger"}>
              {report.psi.cwv.status === "pass" ? "CWV pass" : "CWV fail"}
            </Badge>
          </div>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {Object.entries(report.psi.lighthouse).map(([key, value]) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{key}</p>
                <p class="mt-2 text-2xl text-slate-100">{Math.round(value * 100)}</p>
              </div>
            ))}
          </div>
        </Card>
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Waterfall summary</p>
          <h2 class="mt-2 text-2xl text-slate-100">Load timeline (browser)</h2>
          <p class="mt-2 text-sm text-slate-400">Estimated milestones based on the Lighthouse scan.</p>
          {timeline ? (
            <div class="mt-5 space-y-4">
              <div class="relative h-3 rounded-full bg-white/10">
                <span
                  class="absolute left-0 h-3 rounded-full bg-emerald-400/25"
                  style={`width: ${timelinePct(timeline.fcp)}%`}
                ></span>
                <span
                  class="absolute left-0 h-3 rounded-full bg-sky-400/25"
                  style={`width: ${timelinePct(timeline.lcp)}%`}
                ></span>
                <span
                  class="absolute -top-2 h-7 w-1 rounded-full bg-amber-300"
                  style={`left: ${timelinePct(timeline.ttfb)}%`}
                ></span>
                <span
                  class="absolute -top-2 h-7 w-1 rounded-full bg-emerald-300"
                  style={`left: ${timelinePct(timeline.fcp)}%`}
                ></span>
                <span
                  class="absolute -top-2 h-7 w-1 rounded-full bg-sky-300"
                  style={`left: ${timelinePct(timeline.lcp)}%`}
                ></span>
              </div>
              <div class="grid gap-3 text-sm text-slate-200 md:grid-cols-2">
                <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-2">
                  <span class="text-slate-400">TTFB</span>
                  <span>{formatMs(report.psi.cwv.ttfb_ms)}</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-2">
                  <span class="text-slate-400">FCP</span>
                  <span>{formatMs(report.psi.cwv.fcp_ms)}</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-2">
                  <span class="text-slate-400">LCP</span>
                  <span>{formatMs(report.psi.cwv.lcp_ms)}</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-2">
                  <span class="text-slate-400">Total weight</span>
                  <span>{formatBytes(report.psi.audits.totalByteWeight)}</span>
                </div>
              </div>
            </div>
          ) : null}
        </Card>
        {seoAnalysis ? (
          <Card class="relative">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">SEO analysis</p>
                <h2 class="mt-2 text-2xl text-slate-100">Content health</h2>
                <p class="mt-1 text-xs text-slate-500">
                  {unlocked ? `Score: ${seoAnalysis.score}/100` : "Unlock to view full SEO score and recommendations."}
                </p>
              </div>
            </div>
            {unlocked ? (
              <div class="mt-4 space-y-4">
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-200">
                  <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Primary keyword</p>
                  <p class="mt-2">{seoAnalysis.keywordAnalysis.primaryKeyword ?? "Not provided"}</p>
                  <p class="mt-1 text-xs text-slate-400">Density: {formatPercent(seoAnalysis.keywordAnalysis.density)}</p>
                </div>
                <div class="grid gap-3 text-sm text-slate-200 md:grid-cols-2">
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Title</p>
                    <p class="mt-2">{seoAnalysis.meta.title ?? "Missing"}</p>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Meta description</p>
                    <p class="mt-2">{seoAnalysis.meta.description ?? "Missing"}</p>
                  </div>
                </div>
                <div>
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Top recommendations</p>
                  <ul class="mt-3 space-y-2 text-sm text-slate-200">
                    {seoAnalysis.recommendations.slice(0, 3).map((rec) => (
                      <li class={`rounded-xl border border-white/10 px-3 py-2`}>
                        <p class="text-slate-100">{rec.issue}</p>
                        <p class="text-xs text-slate-400">{rec.recommendation}</p>
                      </li>
                    ))}
                    {seoAnalysis.recommendations.length === 0 ? (
                      <li class="rounded-xl border border-emerald-300/30 bg-emerald-300/10 px-3 py-2 text-emerald-100">
                        No major SEO issues detected.
                      </li>
                    ) : null}
                  </ul>
                </div>
              </div>
            ) : (
              <div class="mt-4 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
                Unlock to reveal keyword density, metadata gaps, and ranked SEO fixes.
              </div>
            )}
            {!unlocked ? (
              <LockedOverlay
                reportId={report.id}
                title="SEO details locked"
                description="Unlock to see full SEO recommendations and keyword insights."
                footnote={null}
              />
            ) : null}
          </Card>
        ) : null}
        {imageAudit ? (
          <Card class="relative">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Image audit</p>
                <h2 class="mt-2 text-2xl text-slate-100">Image optimization</h2>
                <p class="mt-1 text-xs text-slate-500">
                  {unlocked ? `Score: ${imageAudit.score}/100` : "Unlock to view full image optimization analysis."}
                </p>
              </div>
            </div>
            {unlocked ? (
              <div class="mt-4 space-y-4">
                <div class="grid gap-3 text-sm text-slate-200 md:grid-cols-3">
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Total images</p>
                    <p class="mt-2">{imageAudit.totalImages}</p>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Savings</p>
                    <p class="mt-2">{formatBytes(imageAudit.potentialSavings)}</p>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Missing alt</p>
                    <p class="mt-2">{imageAudit.issues.missingAlt}</p>
                  </div>
                </div>
                <div>
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Top recommendations</p>
                  <ul class="mt-3 space-y-2 text-sm text-slate-200">
                    {imageAudit.recommendations.slice(0, 3).map((rec) => (
                      <li class="rounded-xl border border-white/10 px-3 py-2">
                        <p class="text-slate-100">{rec.issue}</p>
                        <p class="text-xs text-slate-400">{rec.recommendation}</p>
                        <p class="mt-1 text-[11px] text-slate-500">{rec.impact}</p>
                      </li>
                    ))}
                    {imageAudit.recommendations.length === 0 ? (
                      <li class="rounded-xl border border-emerald-300/30 bg-emerald-300/10 px-3 py-2 text-emerald-100">
                        Images look optimized.
                      </li>
                    ) : null}
                  </ul>
                </div>
              </div>
            ) : (
              <div class="mt-4 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
                Unlock to see image-level savings, missing alt details, and priority fixes.
              </div>
            )}
            {!unlocked ? (
              <LockedOverlay
                reportId={report.id}
                title="Image audit locked"
                description="Unlock to see full image optimization details."
                footnote={null}
              />
            ) : null}
          </Card>
        ) : null}
        <Card>
          <h2 class="text-2xl text-slate-100">Prioritized fixes</h2>
          <p class="mt-2 text-sm text-slate-400">Filter by severity or category to focus on quick wins.</p>
          <div class="relative mt-6">
            {unlocked ? (
              <ReportFilters client:load insights={report.insights} />
            ) : (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
                Unlock to filter and prioritize the full fix list.
              </div>
            )}
            {!unlocked ? (
              <LockedOverlay reportId={report.id} />
            ) : null}
          </div>
        </Card>
        <Card>
          <h2 class="text-2xl text-slate-100">Fix checklist</h2>
          <p class="mt-2 text-sm text-slate-400">Grouped by category so you can assign work faster.</p>
          <div class="relative mt-6">
            {unlocked ? (
              <div class="space-y-4">
                {groupedInsights.length === 0 ? (
                  <p class="text-sm text-slate-400">No fixes detected yet.</p>
                ) : (
                  groupedInsights.map(([category, items]) => (
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                      <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{category.replace(/-/g, " ")}</p>
                      <ul class="mt-3 space-y-3 text-sm text-slate-200">
                        {items.map((insight) => (
                          <li class="flex gap-3">
                            <span class="mt-1 h-4 w-4 rounded-md border border-white/10 bg-white/5"></span>
                            <div>
                              <p class="text-slate-100">{insight.title}</p>
                              <p class="text-xs text-slate-400">
                                {insight.howToFix[0] ?? "Review audit details"}
                              </p>
                            </div>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))
                )}
              </div>
            ) : (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
                Unlock to see the full dev-ready checklist and category breakdown.
              </div>
            )}
            {!unlocked ? (
              <LockedOverlay reportId={report.id} />
            ) : null}
          </div>
        </Card>
      </div>
    </section>
  ) : (
    <section class="mt-10">
      <Card>
        <h2 class="text-2xl text-slate-100">Report is in progress</h2>
        <p class="mt-2 text-slate-300">We are running a scan and building your report.</p>
        <div class="mt-4">
          <ScanProgress client:load id={id} />
        </div>
      </Card>
    </section>
  )}
</BaseLayout>
