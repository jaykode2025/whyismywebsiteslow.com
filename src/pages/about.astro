---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";

const title = "About whyismywebsiteslow";
const description = "We turn performance data into clear, actionable fixes.";
---
<BaseLayout title={title} description={description}>
  <section class="pt-10">
    <Card>
      <h1 class="text-3xl text-slate-100">Performance clarity for busy teams</h1>
      <p class="mt-4 text-slate-300">
        whyismywebsiteslow helps teams understand the real reasons a site feels slow. We translate Lighthouse
        and Core Web Vitals into clear, prioritized fixes that developers, designers, and marketers can all
        act on.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Method</p>
          <p class="mt-2 text-sm text-slate-300">Real PSI data + smart heuristics.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Output</p>
          <p class="mt-2 text-sm text-slate-300">Beautiful, shareable reports.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Goal</p>
          <p class="mt-2 text-sm text-slate-300">Faster web experiences for everyone.</p>
        </div>
      </div>
    </Card>
  </section>
</BaseLayout>
