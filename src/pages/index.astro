---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import ScanForm from "../components/ScanForm.svelte";

const title = "Why is my website slow? Get answers in 90 seconds.";
const description = "Free Core Web Vitals scan. Get a grade, prioritized fixes, and a shareable report. No signup required.";
---
<BaseLayout title={title} description={description}>
  <section class="pt-10 animate-fade-up">
    <div class="grid items-center gap-10 md:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6 stagger">
        <Badge tone="info">Trusted by 10,000+ website owners</Badge>
        <h1 class="text-4xl leading-tight text-slate-100 sm:text-5xl">
          Your website is losing visitors. <span class="text-sky-400">Let's fix it.</span>
        </h1>
        <p class="text-lg text-slate-300">
          53% of mobile users leave if your site takes over 3 seconds to load. 
          Paste your URL below — get a free performance audit with exact fixes in 90 seconds.
        </p>
        <ScanForm client:load csrfToken={Astro.locals.csrfToken ?? ""} />
        <div class="flex flex-wrap gap-4 text-sm text-slate-400">
          <span>⚡ Powered by Google PageSpeed</span>
          <span>🎯 Prioritized by impact</span>
          <span>📊 Shareable reports</span>
        </div>
      </div>
      <div class="space-y-6">
        <Card class="glow">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Recent scan result</p>
              <h2 class="mt-2 text-2xl text-slate-100">alpha.agency</h2>
            </div>
            <div class="rounded-full border border-emerald-300/30 bg-emerald-300/10 px-4 py-2 text-xs font-semibold text-emerald-200">
              Grade A — 97/100
            </div>
          </div>
          <div class="mt-6 grid grid-cols-3 gap-4 text-center text-sm">
            <div>
              <p class="text-2xl text-sky-200">97</p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Score</p>
            </div>
            <div>
              <p class="text-2xl text-emerald-200">Pass</p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Core Web Vitals</p>
            </div>
            <div>
              <p class="text-2xl text-violet-200">2.1s</p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Load Time</p>
            </div>
          </div>
          <div class="mt-6 space-y-3 text-sm text-slate-300">
            <p>Issues found (and fixed):</p>
            <ul class="space-y-2">
              <li class="flex items-center justify-between rounded-xl border border-white/10 px-3 py-2">
                <span>Render-blocking CSS</span>
                <span class="text-emerald-200">→ Fixed</span>
              </li>
              <li class="flex items-center justify-between rounded-xl border border-white/10 px-3 py-2">
                <span>Unused JavaScript</span>
                <span class="text-emerald-200">→ Fixed</span>
              </li>
              <li class="flex items-center justify-between rounded-xl border border-white/10 px-3 py-2">
                <span>Overweight images</span>
                <span class="text-emerald-200">→ Fixed</span>
              </li>
            </ul>
          </div>
        </Card>
        <Card>
          <h3 class="text-lg text-slate-100">What you'll get — free</h3>
          <ul class="mt-4 space-y-3 text-sm text-slate-300">
            <li class="flex gap-3">
              <span class="text-emerald-400">✓</span>
              <span><strong>Core Web Vitals score</strong> — Pass/Fail in plain English</span>
            </li>
            <li class="flex gap-3">
              <span class="text-emerald-400">✓</span>
              <span><strong>3 quick wins</strong> — Fixes you can do in under an hour</span>
            </li>
            <li class="flex gap-3">
              <span class="text-emerald-400">✓</span>
              <span><strong>Shareable report</strong> — Show your team or clients exactly what needs work</span>
            </li>
          </ul>
          <div class="mt-6 flex items-center gap-3">
            <Button href="/scan" variant="ghost">Advanced scan →</Button>
            <Button href="/report/example">See example report</Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="mt-20 animate-fade-up">
    <div class="grid gap-6 md:grid-cols-3 stagger">
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Backed by Google</p>
        <h3 class="mt-4 text-xl text-slate-100">Powered by PageSpeed Insights</h3>
        <p class="mt-3 text-sm text-slate-300">
          We use Google's official API — the same data that affects your search rankings. 
          Every report is accurate, defensible, and actionable.
        </p>
      </Card>
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">No fluff</p>
        <h3 class="mt-4 text-xl text-slate-100">Fixes in plain English</h3>
        <p class="mt-3 text-sm text-slate-300">
          No jargon. Every insight tells you what's broken, why it matters, and exactly how to fix it.
          Verified by real developers.
        </p>
      </Card>
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Go viral</p>
        <h3 class="mt-4 text-xl text-slate-100">Shareable performance reports</h3>
        <p class="mt-3 text-sm text-slate-300">
          Turn your speed wins into marketing gold. Public, SEO-friendly reports you can share 
          with clients, your boss, or social media.
        </p>
      </Card>
    </div>
  </section>

  <section class="mt-20 animate-fade-up">
    <Card class="relative overflow-hidden">
      <div class="absolute right-[-40%] top-[-40%] h-80 w-80 rounded-full bg-[radial-gradient(circle_at_center,rgba(56,189,248,0.35),transparent)]"></div>
      <div class="relative grid items-center gap-8 md:grid-cols-[1.1fr_0.9fr]">
        <div>
          <h2 class="text-3xl text-slate-100">From slow to blazing fast in 3 steps</h2>
          <p class="mt-3 text-slate-300">
            Most users see a 40% speed improvement after following our recommendations. 
            Here's what happens:
          </p>
        </div>
        <div class="flex flex-col gap-4 text-sm text-slate-300">
          <div class="flex items-center justify-between border-b border-white/10 pb-3">
            <span class="flex items-center gap-3">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/20 text-sky-400 font-semibold text-xs">1</span>
              <span>Scan your site</span>
            </span>
            <span class="text-sky-200">90 seconds</span>
          </div>
          <div class="flex items-center justify-between border-b border-white/10 pb-3">
            <span class="flex items-center gap-3">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/20 text-emerald-400 font-semibold text-xs">2</span>
              <span>Fix quick wins</span>
            </span>
            <span class="text-emerald-200">~1 hour</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="flex items-center gap-3">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-violet-500/20 text-violet-400 font-semibold text-xs">3</span>
              <span>Re-scan &amp; celebrate</span>
            </span>
            <span class="text-violet-200">Instant</span>
          </div>
        </div>
      </div>
    </Card>
  </section>
</BaseLayout>
