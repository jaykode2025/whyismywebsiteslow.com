---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import ScanForm from "../components/ScanForm.svelte";

const title = "Why is my website slow?";
const description = "Run a Core Web Vitals scan, get a score, and ship fixes that move the needle.";
---
<BaseLayout title={title} description={description}>
  <section class="pt-10">
    <div class="grid items-center gap-10 md:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6">
        <Badge tone="info">Performance detective for modern websites</Badge>
        <h1 class="text-4xl leading-tight text-slate-100 sm:text-5xl">
          Find exactly why your website is slow — and how to fix it.
        </h1>
        <p class="text-lg text-slate-300">
          Paste any URL and get a premium performance report with Core Web Vitals, a clean grade, and a
          prioritized checklist.
        </p>
        <ScanForm client:load />
        <div class="flex flex-wrap gap-4 text-sm text-slate-400">
          <span>⚡ Real Lighthouse data via PageSpeed Insights</span>
          <span>🧠 Human-first explanations</span>
          <span>🔗 Public shareable reports</span>
        </div>
      </div>
      <div class="space-y-6">
        <Card class="glow">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Example report</p>
              <h2 class="mt-2 text-2xl text-slate-100">alpha.agency</h2>
            </div>
            <div class="rounded-full border border-emerald-300/30 bg-emerald-300/10 px-4 py-2 text-xs font-semibold text-emerald-200">
              Grade A
            </div>
          </div>
          <div class="mt-6 grid grid-cols-3 gap-4 text-center text-sm">
            <div>
              <p class="text-2xl text-sky-200">97</p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">score</p>
            </div>
            <div>
              <p class="text-2xl text-emerald-200">Pass</p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">CWV</p>
            </div>
            <div>
              <p class="text-2xl text-violet-200">2.1s</p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">LCP</p>
            </div>
          </div>
          <div class="mt-6 space-y-3 text-sm text-slate-300">
            <p>Top bottlenecks</p>
            <ul class="space-y-2">
              <li class="flex items-center justify-between rounded-xl border border-white/10 px-3 py-2">
                <span>Render-blocking CSS</span>
                <span class="text-amber-200">High</span>
              </li>
              <li class="flex items-center justify-between rounded-xl border border-white/10 px-3 py-2">
                <span>Unused JavaScript</span>
                <span class="text-rose-200">Critical</span>
              </li>
              <li class="flex items-center justify-between rounded-xl border border-white/10 px-3 py-2">
                <span>Overweight images</span>
                <span class="text-amber-200">High</span>
              </li>
            </ul>
          </div>
        </Card>
        <Card>
          <h3 class="text-lg text-slate-100">What you get in 90 seconds</h3>
          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li>✓ Core Web Vitals pass/fail</li>
            <li>✓ Score, grade, and top three fixes</li>
            <li>✓ Crawl comparison for up to 5 pages</li>
          </ul>
          <div class="mt-6 flex items-center gap-3">
            <Button href="/scan" variant="ghost">Try advanced scan</Button>
            <Button href="/report/example">View example</Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="mt-20">
    <div class="grid gap-6 md:grid-cols-3">
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Real data</p>
        <h3 class="mt-4 text-xl text-slate-100">Built on Lighthouse + CWV</h3>
        <p class="mt-3 text-sm text-slate-300">
          We use PageSpeed Insights so every report is traceable, defendable, and SEO-aligned.
        </p>
      </Card>
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Actionable</p>
        <h3 class="mt-4 text-xl text-slate-100">Plain-language fixes</h3>
        <p class="mt-3 text-sm text-slate-300">
          No jargon. Every insight explains what it means, why it hurts, and how to verify the fix.
        </p>
      </Card>
      <Card>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Shareable</p>
        <h3 class="mt-4 text-xl text-slate-100">Public reports that rank</h3>
        <p class="mt-3 text-sm text-slate-300">
          Turn performance wins into marketing assets with shareable, indexable reports.
        </p>
      </Card>
    </div>
  </section>

  <section class="mt-20">
    <Card class="relative overflow-hidden">
      <div class="absolute right-[-40%] top-[-40%] h-80 w-80 rounded-full bg-[radial-gradient(circle_at_center,rgba(56,189,248,0.35),transparent)]"></div>
      <div class="relative grid items-center gap-8 md:grid-cols-[1.1fr_0.9fr]">
        <div>
          <h2 class="text-3xl text-slate-100">Get a clear plan in minutes.</h2>
          <p class="mt-3 text-slate-300">
            Every report is structured to match how teams work: fast wins first, deep work second.
          </p>
        </div>
        <div class="flex flex-col gap-4 text-sm text-slate-300">
          <div class="flex items-center justify-between border-b border-white/10 pb-3">
            <span>1. Diagnose bottlenecks</span>
            <span class="text-sky-200">2 min</span>
          </div>
          <div class="flex items-center justify-between border-b border-white/10 pb-3">
            <span>2. Fix quick wins</span>
            <span class="text-emerald-200">1 hour</span>
          </div>
          <div class="flex items-center justify-between">
            <span>3. Benchmark after</span>
            <span class="text-violet-200">Instant</span>
          </div>
        </div>
      </div>
    </Card>
  </section>
</BaseLayout>
