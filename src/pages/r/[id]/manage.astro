---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Card from "../../../components/ui/Card.astro";
import ManageReport from "../../../components/ManageReport.svelte";

const { id } = Astro.params;
const token = Astro.url.searchParams.get("token") ?? "";
---
<BaseLayout title="Manage report" description="Delete or regenerate a report." noindex={true}>
  <section class="pt-10">
    <Card>
      <h1 class="text-3xl text-slate-100">Manage report</h1>
      <p class="mt-2 text-slate-300">Report ID: {id}</p>
      <div class="mt-6">
        <ManageReport client:load id={id} token={token} />
      </div>
    </Card>
  </section>
</BaseLayout>
