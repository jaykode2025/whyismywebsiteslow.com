---
import { PROBLEMS, PLATFORMS, INDUSTRIES } from "../../data/pseo";
import { siteUrl, breadcrumb, organizationSchema } from "../../lib/seo";
import { buildProblemProofDataset } from "../../lib/proof";
import ProofBlock from "../../components/seo/ProofBlock.astro";
import { deriveVariationTokens, sectionOrderMap } from "../../lib/variation";
import { relatedForProblem } from "../../lib/related";
import RelatedLinks from "../../components/seo/RelatedLinks.astro";

// Generate schemas
const breadcrumbSchema = breadcrumb([
  { name: "Home", item: "/" },
  { name: "SEO Issues" }
]);
const orgSchema = organizationSchema();
const featuredProblem = PROBLEMS[0];
const proofDataset = featuredProblem ? buildProblemProofDataset(featuredProblem) : null;
const variationTokens = deriveVariationTokens({
  slug: "why-is-my-website-slow-index",
  availableSections: ["platforms", "problems", "industries"],
});
const sectionOrder = sectionOrderMap(variationTokens.sectionOrder);
const related = featuredProblem ? relatedForProblem(featuredProblem.slug, 5) : [];
const ogImage = featuredProblem
  ? siteUrl(`/og/why-is-my-website-slow/${featuredProblem.slug}.svg`)
  : siteUrl("/og-default.svg");
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Why Is My Website Slow? Common Issues & Solutions</title>
  <meta name="description" content="Discover the most common reasons why websites are slow and learn expert solutions to fix them. Comprehensive guide to website performance optimization." />
  <link rel="canonical" href={siteUrl("/why-is-my-website-slow/")} />
  
  <!-- Schema markup -->
  <script type="application/ld+json">{JSON.stringify(breadcrumbSchema)}</script>
  <script type="application/ld+json">{JSON.stringify(orgSchema)}</script>
  
  <!-- Open Graph / Social Media Tags -->
  <meta property="og:title" content="Why Is My Website Slow? Common Issues & Solutions" />
  <meta property="og:description" content="Discover the most common reasons why websites are slow and learn expert solutions to fix them. Comprehensive guide to website performance optimization." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl("/why-is-my-website-slow/")} />
  <meta property="og:image" content={ogImage} />
</head>
<body>
  <header>
    <nav aria-label="Breadcrumb">
      <ol itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item"><span itemprop="name">Home</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name">SEO Issues</span>
          <meta itemprop="position" content="2" />
        </li>
      </ol>
    </nav>
  </header>

  <main class="flex flex-col">
    <h1>Why Is My Website Slow? Common Issues & Solutions</h1>
    <p>Website speed is critical for user experience, search rankings, and conversions. Explore the most common performance issues affecting different platforms and industries:</p>
    {proofDataset && featuredProblem ? (
      <ProofBlock
        title="Proof Snapshot: Common Speed Bottlenecks"
        subtitle={`Featured issue: ${featuredProblem.h1}`}
        proofType={variationTokens.proofType}
        visualMode={variationTokens.visualMode}
        dataset={proofDataset}
        slug="why-is-my-website-slow-index"
      />
    ) : null}

    <section style={`order:${sectionOrder["platforms"] ?? 1}`}>
      <h2>By Platform</h2>
      <ul>
        {PLATFORMS.map(platform => (
          <li><a href={`/website-speed-audit/platform/${platform.platform}/`} title={`Learn about ${platform.keyword}`}>{platform.keyword}</a></li>
        ))}
      </ul>
    </section>

    <section style={`order:${sectionOrder["problems"] ?? 2}`}>
      <h2>Common Problems</h2>
      <ul>
        {PROBLEMS.map(p=>(
          <li><a href={"/why-is-my-website-slow/"+p.slug+"/"} title={p.metaDescription}>{p.keyword}</a></li>
        ))}
      </ul>
    </section>

    <section style={`order:${sectionOrder["industries"] ?? 3}`}>
      <h2>By Industry</h2>
      <ul>
        {INDUSTRIES.map(industry => (
          <li><a href={`/website-speed-audit/industry/${industry.industry}/`} title={`Website speed audit for ${industry.keyword}`}>{industry.keyword}</a></li>
        ))}
      </ul>
    </section>

    <RelatedLinks items={related} heading="Related fixes and next steps" />

    <section>
      <h2>Need Expert Help?</h2>
      <p>Our comprehensive website speed audits identify all performance bottlenecks and provide prioritized solutions.</p>
      <a href="/website-speed-audit/" class="cta-button">Get Your Free Audit</a>
    </section>
  </main>
</body>
</html>
