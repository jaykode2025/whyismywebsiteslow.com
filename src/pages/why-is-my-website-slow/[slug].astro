---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PROBLEMS, TIER1 } from "../../data/pseo";
import { relatedForProblem } from "../../lib/related";
import RelatedLinks from "../../components/RelatedLinks.astro";
import { siteUrl, breadcrumb, faq, articleSchema, organizationSchema, calculateKeywordDensity } from "../../lib/seo";

export const prerender = false;

const entry = PROBLEMS.find((p) => p.slug === Astro.params.slug);
if (!entry) {
  throw new Error(`Problem not found for slug: ${Astro.params.slug ?? "unknown"}`);
}
const related = relatedForProblem(entry.slug);

const breadcrumbSchema = breadcrumb([
  { name: "Home", item: "/" },
  { name: "SEO Issues", item: "/why-is-my-website-slow/" },
  { name: entry.h1 }
]);
const faqSchema = faq(entry.faqs);
const articleSchemaData = articleSchema(
  entry.h1,
  entry.metaDescription,
  entry.h1,
  new Date().toISOString(),
  new Date().toISOString()
);
const orgSchema = organizationSchema();

const allContent = `${entry.primaryCause} ${entry.quickWins.join(" ")} ${entry.detailedAnalysis.join(" ")} ${entry.solutions.map((s) => `${s.title} ${s.description} ${s.steps.join(" ")}`).join(" ")} ${entry.faqs.map((f) => `${f.question} ${f.answer}`).join(" ")}`;
const keywordDensity = calculateKeywordDensity(allContent, entry.keyword);
---

<BaseLayout title={entry.h1} description={entry.metaDescription} canonical={siteUrl(`/why-is-my-website-slow/${entry.slug}/`)}>
  <nav aria-label="Breadcrumb" class="py-6">
    <ol itemscope itemtype="https://schema.org/BreadcrumbList" class="flex gap-2 text-sm text-slate-400">
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="/" itemprop="item" class="text-sky-400 hover:underline"><span itemprop="name">Home</span></a>
        <meta itemprop="position" content="1" />
      </li>
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="mx-2">/</span>
        <a href="/why-is-my-website-slow/" itemprop="item" class="text-sky-400 hover:underline"><span itemprop="name">SEO Issues</span></a>
        <meta itemprop="position" content="2" />
      </li>
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="mx-2">/</span>
        <span itemprop="name" class="text-slate-300">{entry.h1}</span>
        <meta itemprop="position" content="3" />
      </li>
    </ol>
  </nav>

  <article class="prose prose-invert prose-slate max-w-4xl mx-auto">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-slate-100 mb-4">{entry.h1}</h1>
      <p class="text-lg text-slate-400">{entry.metaDescription}</p>
    </header>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Primary Cause</h2>
      <p class="text-slate-300">{entry.primaryCause}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Quick Wins</h2>
      <ul class="space-y-2">
        {entry.quickWins.map((win) => <li class="text-slate-300">✓ {win}</li>)}
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Detailed Analysis</h2>
      <div class="space-y-3">
        {entry.detailedAnalysis.map((paragraph) => <p class="text-slate-300">{paragraph}</p>)}
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Step-by-Step Solutions</h2>
      {entry.solutions.map((solution) => (
        <div class="bg-white/5 rounded-xl p-6 mb-4 border border-white/10">
          <h3 class="text-xl font-semibold text-slate-100 mb-2">{solution.title}</h3>
          <p class="text-slate-400 mb-4">{solution.description}</p>
          <ol class="list-decimal list-inside space-y-2 text-slate-300">
            {solution.steps.map((step) => <li>{step}</li>)}
          </ol>
        </div>
      ))}
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Statistics &amp; Impact</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {entry.statistics.map((stat) => (
          <div class="bg-gradient-to-br from-sky-500/10 to-violet-500/10 rounded-xl p-6 border border-white/10">
            <div class="text-3xl font-bold text-sky-400">{stat.value}</div>
            <p class="text-sm text-slate-400 mt-2">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Frequently Asked Questions</h2>
      <dl class="space-y-4">
        {entry.faqs.map((faqItem) => (
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <dt class="text-lg font-semibold text-slate-100 mb-2">{faqItem.question}</dt>
            <dd class="text-slate-300">{faqItem.answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">External Resources</h2>
      <ul class="space-y-2">
        {entry.outboundLinks.map((link) => (
          <li class="text-slate-300">
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-sky-400 hover:underline">
              {link.label} ↗
            </a>
          </li>
        ))}
      </ul>
    </section>

    <aside class="bg-gradient-to-r from-sky-500/20 to-violet-500/20 rounded-2xl p-8 border border-white/10 my-8">
      <h2 class="text-2xl font-semibold text-slate-100 mb-3">Ready to Improve Your Site Speed?</h2>
      <p class="text-slate-300 mb-6">{entry.conversionImpact}</p>
      <a href={TIER1.audit} class="inline-block bg-sky-500 hover:bg-sky-400 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
        Get Your Free Website Speed Audit →
      </a>
    </aside>
  </article>

  <RelatedLinks items={related} />
</BaseLayout>
</html>
