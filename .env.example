# --- REQUIRED FOR CORE FLOW ---
# Get these from https://supabase.com
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_... # $99/mo Pro Plan
STRIPE_PRICE_PRO_YEARLY=price_... # $990/yr Pro Plan (save 2 months)
STRIPE_PRICE_AGENCY=price_... # $299/mo Agency Plan
STRIPE_PRICE_REPORT_UNLOCK=price_... # $19 one-time report unlock

# --- OPTIONAL (RECOMMENDED) ---
# Google PageSpeed Insights API key (improves rate limits). The app will still run without a key.
# Create/Manage keys at: https://console.cloud.google.com/
PSI_API_KEY=

# --- REQUIRED FOR BACKGROUND SCANS ---
# Get this from https://console.upstash.com/qstash
QSTASH_TOKEN=your_qstash_token
# Your production URL (e.g., https://whyismywebsiteslow.com)
APP_BASE_URL=http://localhost:4321

# --- OPTIONAL (ALERT EMAILS) ---
# If set, weekly monitoring + regression alerts are emailed via Resend.
RESEND_API_KEY=re_...
ALERT_FROM_EMAIL=alerts@whyismywebsiteslow.com

# --- DISABLED ---
# Playwright/Chromium scanning is disabled in this production build for stability on serverless.
# (You can re-introduce it later using a dedicated worker.)
